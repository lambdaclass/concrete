    #[test]
    fn test_parse_oct_without_prefix() -> i32 {
        let s: String = "17";
        let result: Option<u64> = parse_oct(&s);
        s.drop();
        match result {
            Option::Some { value } => {
                if value != 15 {
                    return 1;
                }
