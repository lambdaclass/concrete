        let result: Option<u64> = parse_hex(&s);
        s.drop();
        match result {
            Option::Some { value } => {
                if value != 255 {
                    return 1;
                }
                return 0;
            },
            Option::None => {
                return 1;
            }
        }
    }

    #[test]
    fn test_parse_hex_without_prefix() -> i32 {
        let s: String = "ff";
        let result: Option<u64> = parse_hex(&s);
        s.drop();
        match result {
            Option::Some { value } => {
                if value != 255 {
                    return 1;
                }
                return 0;
            },
            Option::None => {
                return 1;
