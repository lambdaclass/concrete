    #[test]
    fn test_parse_bool_empty() -> i32 {
        let s: String = String::new();
        let result: Option<bool> = parse_bool(&s);
        s.drop();
        match result {
            Option::Some { value } => { return 1; },
            Option::None => { return 0; }
        }
    }

    #[test]
    fn test_parse_bool_case_sensitive() -> i32 {
        // "True" should fail — only "true" accepted
        let s: String = "True";
        let result: Option<bool> = parse_bool(&s);
        s.drop();
        match result {
            Option::Some { value } => { return 1; },
            Option::None => { return 0; }
        }
    }

    #[test]
    fn test_cursor_eof() -> i32 {
        let s: String = String::new();
        let mut cur: Cursor = Cursor::new(&s);
        if !(cur.is_eof()) {
            s.drop();
            return 1;
        }
        // peek at EOF should return None
        let pk: Option<char> = cur.peek();
        match pk {
            Option::Some { value } => {
                s.drop();
                return 1;
            },
            Option::None => {}
        }
        // advance at EOF should return None
        let adv: Option<char> = cur.advance();
        match adv {
            Option::Some { value } => {
                s.drop();
                return 1;
            },
            Option::None => {}
        }
        // expect_char at EOF should return false
        if cur.expect_char('x') {
            s.drop();
            return 1;
        }
        s.drop();
        return 0;
    }

    #[test]
    fn test_cursor_advance_all() -> i32 {
        let s: String = "ab";
        let mut cur: Cursor = Cursor::new(&s);
        let c1: Option<char> = cur.advance();
        let c2: Option<char> = cur.advance();
        let c3: Option<char> = cur.advance();
        match c1 {
            Option::Some { value } => {
                if value != 'a' {
                    s.drop();
                    return 1;
                }
            },
            Option::None => {
                s.drop();
                return 1;
            }
        }
        match c2 {
            Option::Some { value } => {
                if value != 'b' {
                    s.drop();
                    return 1;
                }
            },
            Option::None => {
                s.drop();
                return 1;
            }
        }
        // c3 should be None (past end)
        match c3 {
            Option::Some { value } => {
                s.drop();
                return 1;
            },
            Option::None => {}
        }
        if !(cur.is_eof()) {
            s.drop();
            return 1;
        }
        s.drop();
        return 0;
    }

    #[test]
    fn test_cursor_skip_whitespace_all() -> i32 {
        // All whitespace string
        let s: String = "   ";
        let mut cur: Cursor = Cursor::new(&s);
        cur.skip_whitespace();
        if !(cur.is_eof()) {
            s.drop();
            return 1;
        }
        s.drop();
        return 0;
    }
}
