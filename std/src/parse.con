    #[test]
    fn test_parse_bin() -> i32 {
        let s: String = "0b1010";
        let result: Option<u64> = parse_bin(&s);
        s.drop();
        match result {
            Option::Some { value } => {
                if value != 10 {
                    return 1;
                }
                return 0;
            },
            Option::None => {
                return 1;
            }
        }
    }

    #[test]
    fn test_parse_oct() -> i32 {
        let s: String = "0o17";
        let result: Option<u64> = parse_oct(&s);
        s.drop();
        match result {
            Option::Some { value } => {
                if value != 15 {
                    return 1;
                }
                return 0;
            },
            Option::None => {
