    #[test]
    fn test_parse_bool_true() -> i32 {
        let s: String = "true";
        let result: Option<bool> = parse_bool(&s);
        s.drop();
        match result {
            Option::Some { value } => {
                if !value {
                    return 1;
                }
                return 0;
            },
            Option::None => {
                return 1;
            }
        }
    }

    #[test]
    fn test_parse_bool_false() -> i32 {
        let s: String = "false";
        let result: Option<bool> = parse_bool(&s);
        s.drop();
        match result {
            Option::Some { value } => {
                if value {
                    return 1;
                }
                return 0;
            },
            Option::None => {
                return 1;
            }
        }
    }

    #[test]
    fn test_parse_bool_invalid() -> i32 {
        let s: String = "yes";
        let result: Option<bool> = parse_bool(&s);
        s.drop();
        match result {
            Option::Some { value } => {
                return 1;
            },
            Option::None => {
                return 0;
            }
        }
    }

    #[test]
    fn test_cursor_basic() -> i32 {
        let s: String = "hello";
        let mut cur: Cursor = Cursor::new(&s);
        if cur.is_eof() {
            s.drop();
            return 1;
        }
        if !assert_eq::<u64>(cur.remaining(), 5, "remaining should be 5") {
            s.drop();
            return 1;
        }
        let ch: Option<char> = cur.advance();
        match ch {
            Option::Some { value } => {
                if value != 'h' {
                    s.drop();
                    return 1;
                }
            },
            Option::None => {
                s.drop();
                return 1;
            }
        }
        if !assert_eq::<u64>(cur.pos(), 1, "pos should be 1 after advance") {
            s.drop();
            return 1;
        }
        s.drop();
        return 0;
    }

    #[test]
    fn test_cursor_skip_whitespace() -> i32 {
        let s: String = "  hi";
        let mut cur: Cursor = Cursor::new(&s);
        cur.skip_whitespace();
        if !assert_eq::<u64>(cur.pos(), 2, "pos should be 2 after skipping spaces") {
            s.drop();
            return 1;
        }
        let ch: Option<char> = cur.peek();
        match ch {
            Option::Some { value } => {
                if value != 'h' {
                    s.drop();
                    return 1;
                }
            },
            Option::None => {
                s.drop();
                return 1;
            }
        }
        s.drop();
        return 0;
    }

    #[test]
    fn test_cursor_expect_char() -> i32 {
        let s: String = "ab";
        let mut cur: Cursor = Cursor::new(&s);
        if !(cur.expect_char('a')) {
            s.drop();
            return 1;
        }
        if cur.expect_char('c') {
            s.drop();
            return 1;
        }
        // pos should be 1 (only 'a' consumed)
        if !assert_eq::<u64>(cur.pos(), 1, "pos should be 1") {
            s.drop();
            return 1;
        }
        s.drop();
        return 0;
    }

    // --- Additional failure-path tests ---

    #[test]
    fn test_parse_int_just_minus() -> i32 {
        let s: String = "-";
        let result: Option<i64> = parse_int(&s);
        s.drop();
        match result {
            Option::Some { value } => { return 1; },
            Option::None => { return 0; }
        }
    }

    #[test]
    fn test_parse_int_mixed_chars() -> i32 {
        let s: String = "12x4";
        let result: Option<i64> = parse_int(&s);
        s.drop();
        match result {
            Option::Some { value } => { return 1; },
            Option::None => { return 0; }
        }
    }

    #[test]
    fn test_parse_uint_negative() -> i32 {
        // parse_uint should reject leading minus
        let s: String = "-5";
        let result: Option<u64> = parse_uint(&s);
        s.drop();
        match result {
            Option::Some { value } => { return 1; },
            Option::None => { return 0; }
        }
    }

