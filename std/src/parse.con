    #[test]
    fn test_parse_hex_uppercase() -> i32 {
        let s: String = "0XAB";
        let result: Option<u64> = parse_hex(&s);
        s.drop();
        match result {
            Option::Some { value } => {
                if value != 171 {
                    return 1;
                }
                return 0;
            },
            Option::None => { return 1; }
        }
    }

