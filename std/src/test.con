mod test {
    import std.io.{println};

    /// Consume-and-ignore a Copy-payload fallible result. The blessed way for
    /// a test to say "this insert/pop result is intentionally unused" — a bare
    /// discard is E0286, and `_` may ignore only Copy values, but the OPTION
    /// itself is linear and must be consumed.
    pub fn ignore_opt<T: Copy>(o: Option<T>) {
        match o {
            Option::Some { value } => {},
            Option::None => {},
        }
    }

    /// Result companion of `ignore_opt`.
    pub fn ignore_res<T: Copy, E: Copy>(r: Result<T, E>) {
        match r {
            Result::Ok { value } => {},
            Result::Err { error } => {},
        }
    }

    pub fn assert_eq<T: Copy>(expected: T, result: T, message: String) with(Console) -> bool {
        if expected != result {
            let msg: String = "Assert error:";
            println(&msg);
            msg.drop();
            println(&message);
            message.drop();
            return false;
        }
        message.drop();
        return true;
    }

    pub fn assert_ne<T: Copy>(a: T, b: T, message: String) with(Console) -> bool {
        if a == b {
            let msg: String = "Assert error (expected not equal):";
            println(&msg);
            msg.drop();
            println(&message);
            message.drop();
            return false;
        }
        message.drop();
        return true;
    }

    pub fn assert_true(value: bool, message: String) with(Console) -> bool {
        if !value {
            let msg: String = "Assert error (expected true):";
            println(&msg);
            msg.drop();
            println(&message);
            message.drop();
            return false;
        }
        message.drop();
        return true;
    }

    pub fn assert_false(value: bool, message: String) with(Console) -> bool {
        if value {
            let msg: String = "Assert error (expected false):";
            println(&msg);
            msg.drop();
            println(&message);
            message.drop();
            return false;
        }
        message.drop();
        return true;
    }

    pub fn assert_gt<T: Copy>(a: T, b: T, message: String) with(Console) -> bool {
        if a <= b {
            let msg: String = "Assert error (expected a > b):";
            println(&msg);
            msg.drop();
            println(&message);
            message.drop();
            return false;
        }
        message.drop();
        return true;
    }

    pub fn assert_lt<T: Copy>(a: T, b: T, message: String) with(Console) -> bool {
        if a >= b {
            let msg: String = "Assert error (expected a < b):";
            println(&msg);
            msg.drop();
            println(&message);
            message.drop();
            return false;
        }
        message.drop();
        return true;
    }

    pub fn assert_ge<T: Copy>(a: T, b: T, message: String) with(Console) -> bool {
        if a < b {
            let msg: String = "Assert error (expected a >= b):";
            println(&msg);
            msg.drop();
            println(&message);
            message.drop();
            return false;
        }
        message.drop();
        return true;
    }

    pub fn assert_le<T: Copy>(a: T, b: T, message: String) with(Console) -> bool {
        if a > b {
            let msg: String = "Assert error (expected a <= b):";
            println(&msg);
            msg.drop();
            println(&message);
            message.drop();
            return false;
        }
        message.drop();
        return true;
    }

    // ================================================================
    // Oracle surface (P7 step 5): tests capture a SINK and compare bytes —
    // the same Writer contract everything renders through, so "test output"
    // and "documented output" are one mechanism (executable-docs direction;
    // cf. check_doc_snippets). Pattern:
    //     let mut st = ...; let w = fixed_writer(&mut st);
    //     <render through w>;
    //     expect_sink(&raw, &st, &"expected") — bytes must match exactly.
    // ================================================================

    // Expected-outcome helpers (the 13t bucket-1 shapes): a test asserting
    // that an operation FAILED is a first-class expectation, not a negation
    // dance. Silent, capability-free, no allocation — combine with
    // assert_true(...) when a message is wanted.
    pub fn expect_ok<T: Copy, E: Copy>(r: &Result<T, E>) -> bool {
        return r.is_ok();
    }
    pub fn expect_err<T: Copy, E: Copy>(r: &Result<T, E>) -> bool {
        return r.is_err();
    }
    pub fn expect_some<T: Copy>(o: &Option<T>) -> bool {
        return o.is_some();
    }
    pub fn expect_none<T: Copy>(o: &Option<T>) -> bool {
        return o.is_none();
    }

    /// Compare captured sink bytes to an expected string, byte-exact.
    pub trusted fn sink_matches(buf: *const u8, len: u64, expected: &String) -> bool {
        if len != expected.len { return false; }
        let mut i: u64 = 0;
        while i < len {
            let got: u8 = *((buf as u64 + i) as *const u8);
            let want: u8 = *((expected.ptr as u64 + i) as *const u8);
            if got != want { return false; }
            i = i + 1;
        }
        return true;
    }

    /// Oracle assertion: captured sink == expected (prints a diff summary on
    /// mismatch). The core expect-helper for render-and-compare tests.
    pub fn expect_sink(buf: *const u8, len: u64, expected: &String, message: String) with(Console) -> bool {
        if sink_matches(buf, len, expected) {
            message.drop();
            return true;
        }
        let mut m: String = "EXPECT-SINK MISMATCH: ";
        m.append(&message);
        println(&m);
        m.drop();
        message.drop();
        return false;
    }

    pub fn str_eq(a: &String, b: &String) -> bool {
        if a.len != b.len {
            return false;
        }
        let mut i: u64 = 0;
        while i < a.len {
            if a.get_unchecked(i) != b.get_unchecked(i) {
                return false;
            }
            i = i + 1;
        }
        return true;
    }

    pub fn assert_str_eq(a: &String, b: &String, message: String) with(Console) -> bool {
        if !str_eq(a, b) {
            let msg: String = "Assert error (strings not equal):";
            println(&msg);
            msg.drop();
            println(&message);
            message.drop();
            return false;
        }
        message.drop();
        return true;
    }
}
