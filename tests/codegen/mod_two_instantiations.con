mod m {
    struct Copy Pair<T> { a: T, b: T }
    struct Copy Hold<T> { item: T }
    // T: Copy — under conditional Copy, Hold<T> is Copy in the body only when
    // T is; unbounded T would make the unconsumed param h an E0208.
    fn tag<T: Copy>(h: Hold<T>) -> i64 { return 9; }
    pub fn main() -> i64 {
        let a: Hold<Pair<i64>>  = Hold::<Pair<i64>>  { item: Pair::<i64>  { a: 1, b: 2 } };
        let b: Hold<Pair<bool>> = Hold::<Pair<bool>> { item: Pair::<bool> { a: true, b: false } };
        return tag(a) + tag(b);
    }
}
