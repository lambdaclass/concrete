// module main
enum Option<T> {
  Some { value: T },
  None,
}

enum Result<T, E> {
  Ok { value: T },
  Err { error: E },
}

enum IntList {
  Nil,
  Cons { head: Int },
}

fn value(l: IntList) -> Int {
  match l {
  IntList::Nil -> {
      return 0;
  }
  IntList::Cons { head.b0: Int } -> {
      return head.b0;
  }
};
}

fn main() -> Int {
  let l: IntList = IntList::Cons { head: 42 };
  return value(l);
}
