// module main
struct Point {
  x: Int,
  y: Int,
}

enum Option<T> {
  Some { value: T },
  None,
}

enum Result<T, E> {
  Ok { value: T },
  Err { error: E },
}

fn sum_point(p: Point) -> Int {
  let __destr_Point: Point = p;
  let x: Int = __destr_Point.x;
  let y: Int = __destr_Point.y;
  return (x + y);
}

fn main() -> Int {
  let p: Point = Point { x: 3, y: 4 };
  return sum_point(p);
}
