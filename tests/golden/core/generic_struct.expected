// module main
struct Pair {
  a: Int,
  b: Int,
}

enum Option<T> {
  Some { value: T },
  None,
}

enum Result<T, E> {
  Ok { value: T },
  Err { error: E },
}

fn sum(p: Pair) -> Int {
  let __destr_Pair: Pair = p;
  let a: Int = __destr_Pair.a;
  let b: Int = __destr_Pair.b;
  return (a + b);
}

fn main() -> Int {
  let p: Pair = Pair { a: 7, b: 3 };
  return sum(p);
}
