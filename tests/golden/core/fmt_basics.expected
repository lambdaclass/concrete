// module main
enum Option<T> {
  Some { value: T },
  None,
}

enum Result<T, E> {
  Ok { value: T },
  Err { error: E },
}

fn add(x: Int, y: Int) -> Int {
  return (x + y);
}

fn main() -> Int {
  let a: Int = add(1, 2);
  let b: Bool = true;
  if b {
    return a;
  } else {
    return 0;
  }
}
