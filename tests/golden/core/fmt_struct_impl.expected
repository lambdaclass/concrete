// module main
struct Point {
  x: Int,
  y: Int,
}

enum Option<T> {
  Some { value: T },
  None,
}

enum Result<T, E> {
  Ok { value: T },
  Err { error: E },
}

fn Point_new(x: Int, y: Int) -> Point {
  return Point { x: x, y: y };
}

fn Point_sum(self: &Point) -> Int {
  return (self.x + self.y);
}
