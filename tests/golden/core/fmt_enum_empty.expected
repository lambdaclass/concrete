// module main
enum Option<T> {
  Some { value: T },
  None,
}

enum Result<T, E> {
  Ok { value: T },
  Err { error: E },
}

enum Color {
  Red,
  Green,
  Blue,
}

fn pick(c: Color) -> Int {
  let r: Int = match c {
  Color::Red -> {
      return 1;
  }
  Color::Green -> {
      return 2;
  }
  Color::Blue -> {
      return 3;
  }
};
  return r;
}
