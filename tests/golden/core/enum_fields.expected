// module main
enum Option<T> {
  Some { value: T },
  None,
}

enum Result<T, E> {
  Ok { value: T },
  Err { error: E },
}

enum Shape {
  Circle { radius: Int },
  Rect { w: Int, h: Int },
}

fn area(s: Shape) -> Int {
  match s {
  Shape::Circle { radius.b0: Int } -> {
      return (radius.b0 * radius.b0);
  }
  Shape::Rect { w.b1: Int, h.b2: Int } -> {
      return (w.b1 * h.b2);
  }
};
}

fn main() -> Int {
  let s: Shape = Shape::Rect { w: 3, h: 4 };
  return area(s);
}
