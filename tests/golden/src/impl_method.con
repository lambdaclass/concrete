struct Counter { value: Int }

impl Counter {
    fn get(&self) -> Int {
        return self.value;
    }
}

fn consume(c: Counter) -> Int {
    let Counter { value } = c; return value; }

fn main() -> Int {
    let c: Counter = Counter { value: 42 };
    let v: Int = c.get();
    let dummy: Int = consume(c);
    return v;
}
