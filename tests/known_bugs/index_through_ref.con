// KNOWN BUG C10 (docs/KNOWN_HOLES.md) — OPEN. ROADMAP Phase 5 #6c.
//
// Borrowing an element of an array reached through a reference (`&arr[i]` where
// `arr: &[T; N]`) fails type resolution with `&<unknown>` (E0220) — the
// array-index element type is not resolved when the array operand is itself a
// reference. Fail-closed (rejects, never miscompiles), but blocks the ergonomic
// `&arr[i]` element-borrow loop form.
//
// THIS PROGRAM CURRENTLY DOES NOT COMPILE (E0220). Lives outside tests/programs/
// so no glob runs it. Expected once fixed: returns 60 (10 + 20 + 30).

struct Copy Sum { total: i64 }

fn addto(acc: &mut Sum, x: &i64) { acc.total = acc.total + *x; }

fn for_each_into(ctx: &mut Sum, arr: &[i64; 3], f: fn(&mut Sum, &i64)) {
    let mut i: u64 = 0;
    while i < 3 {
        f(&mut *ctx, &arr[i]);   // &arr[i] through &[i64;3] -> &<unknown>
        i = i + 1;
    }
}

fn main() -> i64 {
    let mut s: Sum = Sum { total: 0 };
    let arr: [i64; 3] = [10, 20, 30];
    for_each_into(&mut s, &arr, addto);
    return s.total;
}
