// KNOWN BUG C9 (docs/KNOWN_HOLES.md) — OPEN. ROADMAP Phase 5 #6c.
//
// A loop variable that is BOTH loop-carried AND address-taken miscompiles into
// a silent infinite loop: `i` is promoted to an alloca (because of `&i`) and
// also kept as an SSA phi; the two diverge, the init `store 0` lands inside the
// loop body (resetting `i` every iteration), and the loop condition disappears.
//
// THIS PROGRAM CURRENTLY HANGS. It lives outside tests/programs/ so no test
// glob compiles or runs it. Do not register it as a passing test until C9 is
// fixed (or the checker is made to fail-closed and reject it).
//
// Expected once fixed: returns 3 (0 + 1 + 2).

fn rd(x: &i64) -> i64 { return *x; }

fn main() -> i64 {
    let mut i: i64 = 0;
    let mut acc: i64 = 0;
    while i < 3 {
        acc = acc + rd(&i);
        i = i + 1;
    }
    return acc;
}
