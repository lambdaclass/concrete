mod Lib {
    pub struct Point { x: Int, y: Int }
    pub fn make_point(x: Int, y: Int) -> Point {
        return Point { x: x, y: y };
    }
    pub fn consume_point(p: Point) -> Int { return p.x + p.y; }
}

mod Main {
    import Lib.{ Point, make_point, consume_point };
    fn main() -> Int {
        let p: Point = make_point(10, 20);
        return consume_point(p);
    }
}
