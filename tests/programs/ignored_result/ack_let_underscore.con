// Ignored-result (Phase 6 #13): Concrete is linear, so a fallible `Result` cannot be
// swallowed by a catch-all `_` arm — it must be accounted for by exhaustive matching.
// The intentional ignore is spelled by handling every variant and ignoring the Copy
// payloads with `_`. Expected: compiles, prints 7.
mod m {
    fn risky(x: i32) -> Result<i32, i32> {
        if x > 0 { return Result::<i32, i32>::Ok { value: x }; }
        return Result::<i32, i32>::Err { error: 0 - 1 };
    }
    fn main() -> Int {
        match risky(5) { Result::Ok { _ } => {}, Result::Err { _ } => {} }
        return 7;
    }
}
