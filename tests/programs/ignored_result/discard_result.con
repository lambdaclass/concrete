// Ignored-result (Phase 6 #13): a `Result` produced by a statement expression is
// silently discarded. Expected: rejected with E0286.
mod m {
    fn risky(x: i32) -> Result<i32, i32> {
        if x > 0 { return Result::<i32, i32>::Ok { value: x }; }
        return Result::<i32, i32>::Err { error: 0 - 1 };
    }
    fn main() -> Int {
        risky(5);
        return 0;
    }
}
