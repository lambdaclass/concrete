// Ignored-result (Phase 6 #13): an `Option`/`Result` in trailing VALUE position
// (the value of a value-bearing block, no `;`) is not a discard — it flows out as
// the block's value — so it must NOT be flagged. Expected: compiles, prints 7.
mod m {
    fn maybe(x: i32) -> Option<i32> {
        if x > 0 { return Option::<i32>::Some { value: x }; }
        return Option::<i32>::None {};
    }
    fn main() -> Int {
        let o: Option<i32> = if true { maybe(1) } else { maybe(2) };
        match o { Option::Some { _ } => {}, Option::None => {} }
        return 7;
    }
}
