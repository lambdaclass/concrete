// Struct update: `S { f: x, ..base }` overrides f and copies the rest from base.
// Expected: 1
mod m {
    struct Copy S { a: i32, b: i32, c: i32 }
    fn main() -> Int {
        let x: S = S { a: 1, b: 2, c: 3 };
        let y: S = S { b: 9, ..x };        // b overridden, a & c from x
        if y.a == 1 && y.b == 9 && y.c == 3 { return 1; }
        return 0;
    }
}
