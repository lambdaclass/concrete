// Adversarial: proof blocked (unsupported construct) pressure test.
// Each function is eligible but uses exactly one unsupported construct.
// The diagnostic must name the specific construct, not just "blocked".
//
// NB: struct literal, match, and if-without-else became proof-EXTRACTABLE
// (commit e2ab5eef, 2026-05-23: "ProofCore extracts struct literal + field
// access"), so the original struct/match/if-without-else blockers no longer
// block. To keep five distinct named-blocker cases, those three were repointed
// at constructs that remain durably unmodeled in ProvableV1 — integer division
// (no PBinOp.div), field assignment, and deref — the same approach used for the
// classify_range fix in commit 8a53c3db.
//
// Expected:
//   uses_div          → blocked: unsupported operator (integer division)
//   uses_field_assign → blocked: field assignment
//   uses_mut          → blocked: mutable assignment
//   uses_string       → blocked: string literal
//   uses_deref        → blocked: deref (borrow, deref)
//   extractable_fn    → eligible, extractable (control: should be missing)

struct Copy Point {
    x: Int,
    y: Int,
}

fn uses_div(x: Int) -> Int {
    return x / 2;
}

fn uses_field_assign(x: Int) -> Int {
    let mut p: Point = Point { x: x, y: x };
    p.x = x;
    return p.x;
}

fn uses_mut(x: Int) -> Int {
    let mut r: Int = x;
    r = r + 1;
    return r;
}

fn uses_string() -> String {
    return "hello";
}

fn uses_deref(x: Int) -> Int {
    let r: &Int = &x;
    return *r;
}

fn extractable_fn(a: Int, b: Int) -> Int {
    return a + b;
}

pub fn main() -> Int {
    return extractable_fn(1, 2);
}
