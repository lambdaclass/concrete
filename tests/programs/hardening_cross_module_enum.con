// Hardening test: cross-module enum propagation.
// Verifies that enums defined in one module work correctly when imported
// by another module — variant construction, matching, and field access.
// Expected output: 42

mod Shapes {
    pub enum Copy Shape {
        Circle { radius: i32 },
        Rect { width: i32, height: i32 },
        Triangle { base: i32, height: i32 },
    }

    pub fn area(s: &Shape) -> i32 {
        match *s {
            Shape::Circle { radius } => { return radius * radius * 3; },
            Shape::Rect { width, height } => { return width * height; },
            Shape::Triangle { base, height } => { return base * height / 2; }
        }
    }

    pub fn get_radius(s: &Shape) -> i32 {
        match *s {
            Shape::Circle { radius } => { return radius; },
            Shape::Rect { width, height } => { return 0; },
            Shape::Triangle { base, height } => { return 0; }
        }
    }
}

mod Main {
    import Shapes.{ Shape, area, get_radius };

    fn main() with(Std) -> Int {
        // Construct enums from imported type in consuming module
        let c: Shape = Shape::Circle { radius: 2 };
        let r: Shape = Shape::Rect { width: 3, height: 5 };
        let t: Shape = Shape::Triangle { base: 6, height: 4 };

        // Call cross-module function that matches on the enum
        let ca: i32 = area(&c);   // 2*2*3 = 12
        if ca != 12 { return 1; }

        let ra: i32 = area(&r);   // 3*5 = 15
        if ra != 15 { return 2; }

        let ta: i32 = area(&t);   // 6*4/2 = 12
        if ta != 12 { return 3; }

        // Cross-module match via function on imported enum
        let cr: i32 = get_radius(&c);  // 2
        if cr != 2 { return 4; }

        let rr: i32 = get_radius(&r);  // 0
        if rr != 0 { return 5; }

        // ca(12) + ra(15) + ta(12) + cr(2) + 1 = 42
        let result: i32 = ca + ra + ta + cr + 1;
        if result != 42 { return 6; }

        return result as Int;
    }
}
