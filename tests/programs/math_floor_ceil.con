trusted extern fn floor(x: Float64) -> Float64;
trusted extern fn ceil(x: Float64) -> Float64;

fn main() -> Int {
    let x: Float64 = 3.7;
    let y: Float64 = 3.2;
    let f: Float64 = floor(x);
    let c: Float64 = ceil(y);
    let result: Int = (f as Int) * 10 + (c as Int);
    return result;
}
