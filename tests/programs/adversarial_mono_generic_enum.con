// Adversarial monomorphization: generic enum with 3 type instantiations
// (Maybe<Int> is 8 bytes, Maybe<i32> is 4 — the bug-051 corrupting class).
// TEMPORARILY REJECTED with E0808 (R-0001 containment): user generic enums
// are not yet monomorphized, so this is refused fail-closed rather than
// compiled with a corrupt single-type layout. When per-instantiation enum
// monomorphization lands (R-0001 root fix), restore this to `run_ok 42`.

enum Copy Maybe<T> {
    Just { val: T },
    Nothing {},
}

fn extract_int(m: Maybe<Int>, default: Int) -> Int {
    match m {
        Maybe::Just { val } => { return val; },
        Maybe::Nothing {} => { return default; },
    }
}

fn extract_i32(m: Maybe<i32>, default: i32) -> i32 {
    match m {
        Maybe::Just { val } => { return val; },
        Maybe::Nothing {} => { return default; },
    }
}

pub fn main() -> Int {
    let a: Maybe<Int> = Maybe::<Int>::Just { val: 20 };
    let b: Maybe<i32> = Maybe::<i32>::Just { val: 12 };
    let c: Maybe<Int> = Maybe::<Int>::Nothing {};
    return extract_int(a, 0) + (extract_i32(b, 0) as Int) + extract_int(c, 10);
}
