// Option<T> with Heap for recursive linked list
struct Node {
    value: Int,
    next: Option<Heap<Node>>
}

fn sum_list(node: Node) with(Alloc) -> Int {
    let v: Int = node.value;
    match node.next {
        Option::Some { value } => {
            let inner: Node = *value;
            let rest: Int = sum_list(inner);
            return v + rest;
        },
        Option::None {} => {
            return v;
        },
    }
}

fn main() with(Std) -> Int {
    let n3: Node = Node { value: 12, next: Option::None {} };
    let n2: Node = Node { value: 20, next: Option::Some { value: alloc(n3) } };
    let n1: Node = Node { value: 10, next: Option::Some { value: alloc(n2) } };
    let result: Int = sum_list(n1);
    return result;
}
