// Option<T> with Heap for recursive linked list.
// Linear-clean: each call destructures its node (consuming it) and moves the
// child out of the heap box (which consumes the box) — no leak on any return
// path (the return-path consumption rule enforces this).
struct Node {
    val: Int,
    next: Option<Heap<Node>>
}

fn sum_list(node: Node) with(Alloc) -> Int {
    let Node { val, next } = node;
    match next {
        Option::Some { value } => {
            // `*value` moves the node out of the heap box, consuming `value`.
            let inner: Node = *value;
            let rest: Int = sum_list(inner);
            return val + rest;
        },
        Option::None {} => {
            return val;
        },
    }
}

fn main() with(Std) -> Int {
    let n3: Node = Node { val: 12, next: Option::None {} };
    let n2: Node = Node { val: 20, next: Option::Some { value: alloc(n3) } };
    let n1: Node = Node { val: 10, next: Option::Some { value: alloc(n2) } };
    let result: Int = sum_list(n1);
    return result;
}
