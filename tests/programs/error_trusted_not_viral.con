// Error: a non-trusted function tries to do pointer arithmetic
// Tests that trusted doesn't "leak" to callers
trusted fn safe_offset(p: *mut u8, n: u64) -> *mut u8 {
    let q: *mut u8 = p + n;
    return q;
}

fn not_trusted(p: *mut u8, n: u64) -> *mut u8 {
    let q: *mut u8 = p + n;
    return q;
}

fn main() -> i32 {
    return 0;
}
