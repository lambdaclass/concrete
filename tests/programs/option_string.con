// Option<String> — tests that the enum payload is large enough for String (16 bytes)
// Expected output: 2
fn main() -> Int {
    let s: String = "hi";
    let some_val: Option<String> = Option::Some { value: s };
    match some_val {
        Option::Some { value } => {
            let len: Int = string_length(&value);
            drop_string(value);
            return len;
        },
        Option::None {} => {
            return 0;
        },
    }
}
