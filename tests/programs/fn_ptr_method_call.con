struct Copy Hasher {
    hash_fn: fn(u64) -> u64,
    eq_fn: fn(u64, u64) -> bool,
}

fn my_hash(k: u64) -> u64 { return k * 7; }
fn my_eq(a: u64, b: u64) -> bool { return a == b; }

impl Hasher {
    fn compute(&self, key: u64) -> u64 {
        let f: fn(u64) -> u64 = self.hash_fn;
        return f(key);
    }
}

fn main() -> Int {
    let h: Hasher = Hasher { hash_fn: my_hash, eq_fn: my_eq };
    let v: u64 = h.compute(6);
    return v as Int;
}
