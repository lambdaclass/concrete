// Test: linear struct consumed in every match arm
struct Resource { value: Int }

fn consume(r: Resource) -> Int {
    return r.value;
}

enum Choice { A {}, B {}, C {} }

fn pick(ch: Choice, r: Resource) -> Int {
    match ch {
        Choice::A {} => { return consume(r); },
        Choice::B {} => { return consume(r); },
        Choice::C {} => { return consume(r); },
    }
}

fn main() -> Int {
    let r: Resource = Resource { value: 42 };
    let ch: Choice = Choice::A {};
    return pick(ch, r);
}
