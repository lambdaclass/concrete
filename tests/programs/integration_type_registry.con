// Integration test: type registry/catalog system with multi-module architecture.
//
// Exercises:
// - 3 modules with cross-module type imports
// - Multiple enums (TypeKind 3 variants, Severity 3 variants)
// - Vec of encoded data (parallel arrays pattern)
// - Complex enum matching with nested logic
// - Validation logic with numeric computation chains
// - Trait dispatch for type metrics
// - While loops, function call chains across modules
// - Capability propagation through 3 modules
//
// Expected output: 42

mod Types {
    pub enum Copy TypeKind {
        Scalar { bits: i32 },
        Aggregate { field_count: i32, total_bits: i32 },
        Special { tag: i32 },
    }

    pub enum Copy Severity {
        Error { code: i32 },
        Warning { code: i32 },
        Ok {},
    }

    pub struct Copy TypeInfo {
        name_len: i32,
        size: i32,
        alignment: i32,
        kind_tag: i32,
        kind_param1: i32,
        kind_param2: i32,
    }

    pub trait Measurable {
        fn metric(&self) -> i32;
    }

    impl Measurable for TypeInfo {
        fn metric(&self) -> i32 {
            return self.size * self.alignment;
        }
    }

    pub fn get_kind(kind_tag: i32, p1: i32, p2: i32) -> TypeKind {
        if kind_tag == 0 {
            return TypeKind::Scalar { bits: p1 };
        }
        if kind_tag == 1 {
            return TypeKind::Aggregate { field_count: p1, total_bits: p2 };
        }
        return TypeKind::Special { tag: p1 };
    }

    pub fn kind_complexity(kind: &TypeKind) -> i32 {
        match *kind {
            TypeKind::Scalar { bits } => { return bits / 8; },
            TypeKind::Aggregate { field_count, total_bits } => {
                return field_count * 3 + total_bits / 8;
            },
            TypeKind::Special { tag } => { return tag * 5; }
        }
    }

    pub fn compute_metric<T: Measurable>(item: &T) -> i32 {
        return item.metric();
    }
}

mod Registry {
    import Types.{ TypeKind, get_kind, kind_complexity, Severity };

    // Registry stores entries as 6 consecutive i32 values per entry:
    // [name_len, size, alignment, kind_tag, kind_param1, kind_param2]

    pub fn registry_add(reg: &mut Vec<i32>,
        name_len: i32, size: i32, alignment: i32,
        kind_tag: i32, kind_param1: i32, kind_param2: i32
    ) with(Alloc) {
        vec_push::<i32>(reg, name_len);
        vec_push::<i32>(reg, size);
        vec_push::<i32>(reg, alignment);
        vec_push::<i32>(reg, kind_tag);
        vec_push::<i32>(reg, kind_param1);
        vec_push::<i32>(reg, kind_param2);
    }

    pub fn registry_count(reg: &Vec<i32>) -> i32 {
        return vec_len::<i32>(reg) as i32 / 6;
    }

    pub fn total_size(reg: &Vec<i32>) -> i32 {
        let count: i32 = registry_count(reg);
        let mut sum: i32 = 0;
        let mut i: i32 = 0;
        while i < count {
            let base: Int = (i * 6) as Int;
            sum = sum + vec_get::<i32>(reg, base + 1);
            i = i + 1;
        }
        return sum;
    }

    pub fn count_by_kind(reg: &Vec<i32>, kind_tag: i32) -> i32 {
        let count: i32 = registry_count(reg);
        let mut result: i32 = 0;
        let mut i: i32 = 0;
        while i < count {
            let base: Int = (i * 6) as Int;
            if vec_get::<i32>(reg, base + 3) == kind_tag { result = result + 1; }
            i = i + 1;
        }
        return result;
    }

    pub fn max_metric(reg: &Vec<i32>) -> i32 {
        let count: i32 = registry_count(reg);
        let mut best: i32 = 0;
        let mut i: i32 = 0;
        while i < count {
            let base: Int = (i * 6) as Int;
            let s: i32 = vec_get::<i32>(reg, base + 1);
            let a: i32 = vec_get::<i32>(reg, base + 2);
            let m: i32 = s * a;
            if m > best { best = m; }
            i = i + 1;
        }
        return best;
    }

    pub fn total_complexity(reg: &Vec<i32>) -> i32 {
        let count: i32 = registry_count(reg);
        let mut sum: i32 = 0;
        let mut i: i32 = 0;
        while i < count {
            let base: Int = (i * 6) as Int;
            let kt: i32 = vec_get::<i32>(reg, base + 3);
            let p1: i32 = vec_get::<i32>(reg, base + 4);
            let p2: i32 = vec_get::<i32>(reg, base + 5);
            let kind: TypeKind = get_kind(kt, p1, p2);
            sum = sum + kind_complexity(&kind);
            i = i + 1;
        }
        return sum;
    }

    fn is_power_of_two(n: i32) -> bool {
        if n <= 0 { return false; }
        let mut val: i32 = n;
        while val > 1 {
            if val / 2 * 2 != val { return false; }
            val = val / 2;
        }
        return true;
    }

    pub fn validate_entry(size: i32, alignment: i32) -> Severity {
        if size <= 0 { return Severity::Error { code: 1 }; }
        if alignment <= 0 { return Severity::Error { code: 2 }; }
        if !is_power_of_two(alignment) { return Severity::Warning { code: 3 }; }
        if size / alignment * alignment != size {
            return Severity::Warning { code: 4 };
        }
        return Severity::Ok {};
    }

    pub fn count_issues(reg: &Vec<i32>) -> i32 {
        let count: i32 = registry_count(reg);
        let mut errors: i32 = 0;
        let mut warnings: i32 = 0;
        let mut i: i32 = 0;
        while i < count {
            let base: Int = (i * 6) as Int;
            let s: i32 = vec_get::<i32>(reg, base + 1);
            let a: i32 = vec_get::<i32>(reg, base + 2);
            let sev: Severity = validate_entry(s, a);
            match sev {
                Severity::Error { code } => { errors = errors + 1; },
                Severity::Warning { code } => { warnings = warnings + 1; },
                Severity::Ok {} => {},
            }
            i = i + 1;
        }
        return errors * 1000 + warnings;
    }
}

mod Main {
    import Registry.{ registry_add, registry_count, total_size, count_by_kind, max_metric, total_complexity, count_issues };

    fn main() with(Std) -> Int {
        let mut reg: Vec<i32> = vec_new::<i32>();

        // 0: i8 — Scalar(8), size=1, align=1
        registry_add(&mut reg, 2, 1, 1, 0, 8, 0);
        // 1: i16 — Scalar(16), size=2, align=2
        registry_add(&mut reg, 3, 2, 2, 0, 16, 0);
        // 2: i32 — Scalar(32), size=4, align=4
        registry_add(&mut reg, 3, 4, 4, 0, 32, 0);
        // 3: i64 — Scalar(64), size=8, align=8
        registry_add(&mut reg, 3, 8, 8, 0, 64, 0);
        // 4: Point — Aggregate(2 fields, 64 bits), size=8, align=4
        registry_add(&mut reg, 5, 8, 4, 1, 2, 64);
        // 5: Rect — Aggregate(4 fields, 128 bits), size=16, align=4
        registry_add(&mut reg, 4, 16, 4, 1, 4, 128);
        // 6: Vec<T> — Special(tag=1), size=24, align=8
        registry_add(&mut reg, 6, 24, 8, 2, 1, 0);
        // 7: String — Special(tag=2), size=24, align=8
        registry_add(&mut reg, 6, 24, 8, 2, 2, 0);
        // 8: Triple — Aggregate(3 fields, 96 bits), size=12, align=3 (bad alignment!)
        registry_add(&mut reg, 6, 12, 3, 1, 3, 96);

        let count: i32 = registry_count(&reg);
        if count != 9 { vec_free::<i32>(reg); return 1; }

        // Total size: 1+2+4+8+8+16+24+24+12 = 99
        if total_size(&reg) != 99 { vec_free::<i32>(reg); return 2; }

        let scalars: i32 = count_by_kind(&reg, 0);     // 4
        let aggregates: i32 = count_by_kind(&reg, 1);   // 3
        let specials: i32 = count_by_kind(&reg, 2);     // 2
        if scalars != 4 { vec_free::<i32>(reg); return 3; }
        if aggregates != 3 { vec_free::<i32>(reg); return 4; }
        if specials != 2 { vec_free::<i32>(reg); return 5; }

        // Max metric (size*align): Vec/String = 24*8 = 192
        if max_metric(&reg) != 192 { vec_free::<i32>(reg); return 6; }

        // Complexity: Scalars(1+2+4+8=15) + Agg(2*3+8=14, 4*3+16=28, 3*3+12=21) + Spec(1*5=5, 2*5=10)
        // = 15 + 63 + 15 = 93
        if total_complexity(&reg) != 93 { vec_free::<i32>(reg); return 7; }

        // Validation: entry 8 has align=3 (not power of 2) => 1 warning, 0 errors
        let issues: i32 = count_issues(&reg);
        if issues != 1 { vec_free::<i32>(reg); return 8; }

        // Checksum: scalars(4) * count(9) + aggregates(3) * specials(2) = 36+6 = 42
        let checksum: i32 = scalars * count + aggregates * specials;
        if checksum != 42 { vec_free::<i32>(reg); return 9; }

        vec_free::<i32>(reg);
        return checksum as Int;
    }
}
