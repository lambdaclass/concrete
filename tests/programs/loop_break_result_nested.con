// Migration of the removed value `while … else` (Phase 6D item 2): nested
// loops each carrying a result variable. Replaces while_expr_nested.con with
// identical behavior. Expected: 6
fn main() -> Int {
    let mut i: Int = 0;
    let mut x: Int = 0;
    while i < 10 {
        i = i + 1;
        let mut j: Int = 0;
        let mut inner: Int = 0;
        while j < 5 {
            j = j + 1;
            if j == 3 {
                inner = j;
                break;
            }
        }
        if inner + i == 6 {
            x = inner + i;
            break;
        }
    }
    return x;
}
