// Adversarial test: array of linear elements is itself linear.
// Passing it into a function consumes it at the CALLER (sound, gated). But
// the CALLEE then owns a `[Resource; 2]` it cannot discharge: since H11
// there is no by-value element move-out, and array destructure patterns do
// not exist yet (workload-gated follow-up, ROADMAP 13b / KNOWN_HOLES H11
// note). With params holding real obligations (H17), an owned array of
// linear values is honestly INEXPRESSIBLE to consume — this fixture asserts
// the E0208 instead of pretending the leak is fine. Flip back to a positive
// run when array destructure lands.
// Expected: error — 'arr' was never consumed

struct Resource {
    value: Int,
}

fn consume_array(arr: [Resource; 2]) -> Int {
    return 0;
}

fn linear_array_consumed() -> Int {
    let arr: [Resource; 2] = [Resource { value: 1 }, Resource { value: 2 }];
    let _x: Int = consume_array(arr);
    return 0;
}

fn main() -> Int {
    return linear_array_consumed();
}
