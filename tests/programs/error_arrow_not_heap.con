// 6D#3: postfix `->` is REMOVED grammar — field access is `.` (auto-derefs
// heap shells and references one layer). The parser rejects `->` in member
// position with a migration hint.
struct Copy Point { x: Int, y: Int }

fn main() -> Int {
    let p: Point = Point { x: 1, y: 2 };
    return p->x;
}
