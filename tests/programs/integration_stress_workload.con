// Integration stress test: bytecode interpreter
//
// Simulates a stack-based virtual machine that executes 21 bytecode instructions
// computing factorial(5) = 120, then (3+7)*2 = 20, then 120 - 20 - 58 = 42.
//
// Exercises:
// - 11-variant enum with three deep match expressions (tag_of, operand_of, decode)
// - Multiple Vec instances (program buffer + execution stack)
// - Tight while loop executing 21 instructions
// - Cross-module types and function calls (4 modules)
// - vec_set for proper stack push/pop semantics
// - Numeric computation chains (factorial via unrolled multiply)
// - Integer encoding/decoding of opcodes (program as Vec<i32> pairs)
// - Capability propagation (Alloc through all Vec-using functions)
// - Register save/load across instruction boundaries
//
// Expected exit code: 42

mod Opcode {
    pub enum Copy Op {
        Push { val: i32 },
        Pop {},
        Add {},
        Sub {},
        Mul {},
        Dup {},
        Swap {},
        LoadConst { c: i32 },
        Store { slot: i32 },
        Load { slot: i32 },
        Halt {},
    }

    pub fn tag_of(op: &Op) -> i32 {
        match *op {
            Op::Push { val }       => { return 0; },
            Op::Pop {}             => { return 1; },
            Op::Add {}             => { return 2; },
            Op::Sub {}             => { return 3; },
            Op::Mul {}             => { return 4; },
            Op::Dup {}             => { return 5; },
            Op::Swap {}            => { return 6; },
            Op::LoadConst { c }    => { return 7; },
            Op::Store { slot }     => { return 8; },
            Op::Load { slot }      => { return 9; },
            Op::Halt {}            => { return 10; }
        }
    }

    pub fn operand_of(op: &Op) -> i32 {
        match *op {
            Op::Push { val }       => { return val; },
            Op::Pop {}             => { return 0; },
            Op::Add {}             => { return 0; },
            Op::Sub {}             => { return 0; },
            Op::Mul {}             => { return 0; },
            Op::Dup {}             => { return 0; },
            Op::Swap {}            => { return 0; },
            Op::LoadConst { c }    => { return c; },
            Op::Store { slot }     => { return slot; },
            Op::Load { slot }      => { return slot; },
            Op::Halt {}            => { return 0; }
        }
    }

    pub fn decode(tag: i32, operand: i32) -> Op {
        if tag == 0  { return Op::Push { val: operand }; }
        if tag == 1  { return Op::Pop {}; }
        if tag == 2  { return Op::Add {}; }
        if tag == 3  { return Op::Sub {}; }
        if tag == 4  { return Op::Mul {}; }
        if tag == 5  { return Op::Dup {}; }
        if tag == 6  { return Op::Swap {}; }
        if tag == 7  { return Op::LoadConst { c: operand }; }
        if tag == 8  { return Op::Store { slot: operand }; }
        if tag == 9  { return Op::Load { slot: operand }; }
        return Op::Halt {};
    }
}

mod Stack {
    // Proper stack using Vec<i32> with vec_set for reuse of slots.

    pub fn push(stack: &mut Vec<i32>, sp: &mut i32, val: i32) with(Alloc) {
        let idx: Int = *sp as Int;
        if idx >= vec_len::<i32>(stack) {
            vec_push::<i32>(stack, val);
        } else {
            vec_set::<i32>(stack, idx, val);
        }
        *sp = *sp + 1;
    }

    pub fn pop(stack: &Vec<i32>, sp: &mut i32) -> i32 {
        *sp = *sp - 1;
        return vec_get::<i32>(stack, (*sp) as Int);
    }

    pub fn top(stack: &Vec<i32>, sp: i32) -> i32 {
        return vec_get::<i32>(stack, (sp - 1) as Int);
    }
}

mod Verify {
    import Opcode.{ Op, tag_of, operand_of };

    // Verify encode/decode roundtrip for all opcodes
    pub fn verify_opcodes() -> i32 {
        let ops_ok: i32 = 0;

        let op0: Op = Op::Push { val: 42 };
        if tag_of(&op0) != 0 { return 1; }
        if operand_of(&op0) != 42 { return 2; }

        let op1: Op = Op::Pop {};
        if tag_of(&op1) != 1 { return 3; }

        let op2: Op = Op::Add {};
        if tag_of(&op2) != 2 { return 4; }

        let op3: Op = Op::Sub {};
        if tag_of(&op3) != 3 { return 5; }

        let op4: Op = Op::Mul {};
        if tag_of(&op4) != 4 { return 6; }

        let op5: Op = Op::Dup {};
        if tag_of(&op5) != 5 { return 7; }

        let op6: Op = Op::Swap {};
        if tag_of(&op6) != 6 { return 8; }

        let op7: Op = Op::LoadConst { c: 99 };
        if tag_of(&op7) != 7 { return 9; }
        if operand_of(&op7) != 99 { return 10; }

        let op8: Op = Op::Store { slot: 1 };
        if tag_of(&op8) != 8 { return 11; }

        let op9: Op = Op::Load { slot: 0 };
        if tag_of(&op9) != 9 { return 12; }

        let op10: Op = Op::Halt {};
        if tag_of(&op10) != 10 { return 13; }

        return 0;
    }
}

mod Main {
    import Opcode.{ Op, decode };
    import Stack.{ push, pop, top };
    import Verify.{ verify_opcodes };

    fn emit(prog: &mut Vec<i32>, tag: i32, operand: i32) with(Alloc) {
        vec_push::<i32>(prog, tag);
        vec_push::<i32>(prog, operand);
    }

    fn main() with(Std) -> Int {
        // Verify all 11 opcodes
        let vr: i32 = verify_opcodes();
        if vr != 0 { return (vr as Int) + 100; }

        // Build bytecode program: 21 instructions
        let mut prog: Vec<i32> = vec_new::<i32>();

        // Compute 5! = 120
        emit(&mut prog, 0, 1);    // 0: push 1
        emit(&mut prog, 0, 5);    // 1: push 5
        emit(&mut prog, 4, 0);    // 2: mul -> 5
        emit(&mut prog, 0, 4);    // 3: push 4
        emit(&mut prog, 4, 0);    // 4: mul -> 20
        emit(&mut prog, 0, 3);    // 5: push 3
        emit(&mut prog, 4, 0);    // 6: mul -> 60
        emit(&mut prog, 0, 2);    // 7: push 2
        emit(&mut prog, 4, 0);    // 8: mul -> 120
        emit(&mut prog, 8, 0);    // 9: store r0 = 120

        // Compute (3+7)*2 = 20
        emit(&mut prog, 0, 3);    // 10: push 3
        emit(&mut prog, 0, 7);    // 11: push 7
        emit(&mut prog, 2, 0);    // 12: add -> 10
        emit(&mut prog, 5, 0);    // 13: dup -> 10,10
        emit(&mut prog, 2, 0);    // 14: add -> 20

        // 120 - 20 = 100, 100 - 58 = 42
        emit(&mut prog, 9, 0);    // 15: load r0 -> 120
        emit(&mut prog, 6, 0);    // 16: swap -> 120,20 becomes 20,120
        emit(&mut prog, 3, 0);    // 17: sub -> 120-20=100
        emit(&mut prog, 0, 58);   // 18: push 58
        emit(&mut prog, 3, 0);    // 19: sub -> 100-58=42
        emit(&mut prog, 10, 0);   // 20: halt

        let prog_words: i32 = vec_len::<i32>(&prog) as i32;
        if prog_words != 42 {
            vec_free::<i32>(prog);
            return 1 as Int;
        }

        // Execute
        let mut stack: Vec<i32> = vec_new::<i32>();
        let mut sp: i32 = 0;
        let mut pc: i32 = 0;
        let mut reg0: i32 = 0;
        let mut halted: i32 = 0;
        let num_instr: i32 = prog_words / 2;
        let mut steps: i32 = 0;

        while halted == 0 {
            if pc >= num_instr {
                halted = 1;
            } else {
                let idx: Int = (pc * 2) as Int;
                let tag: i32 = vec_get::<i32>(&prog, idx);
                let operand: i32 = vec_get::<i32>(&prog, idx + 1);

                if tag == 0 {
                    push(&mut stack, &mut sp, operand);
                    pc = pc + 1;
                } else if tag == 1 {
                    let unused: i32 = pop(&stack, &mut sp);
                    pc = pc + 1;
                } else if tag == 2 {
                    let a: i32 = pop(&stack, &mut sp);
                    let b: i32 = pop(&stack, &mut sp);
                    push(&mut stack, &mut sp, b + a);
                    pc = pc + 1;
                } else if tag == 3 {
                    let a: i32 = pop(&stack, &mut sp);
                    let b: i32 = pop(&stack, &mut sp);
                    push(&mut stack, &mut sp, b - a);
                    pc = pc + 1;
                } else if tag == 4 {
                    let a: i32 = pop(&stack, &mut sp);
                    let b: i32 = pop(&stack, &mut sp);
                    push(&mut stack, &mut sp, b * a);
                    pc = pc + 1;
                } else if tag == 5 {
                    let t: i32 = top(&stack, sp);
                    push(&mut stack, &mut sp, t);
                    pc = pc + 1;
                } else if tag == 6 {
                    let a: i32 = pop(&stack, &mut sp);
                    let b: i32 = pop(&stack, &mut sp);
                    push(&mut stack, &mut sp, a);
                    push(&mut stack, &mut sp, b);
                    pc = pc + 1;
                } else if tag == 8 {
                    let val: i32 = pop(&stack, &mut sp);
                    reg0 = val;
                    pc = pc + 1;
                } else if tag == 9 {
                    push(&mut stack, &mut sp, reg0);
                    pc = pc + 1;
                } else if tag == 10 {
                    halted = 1;
                } else {
                    pc = pc + 1;
                }
                steps = steps + 1;
            }
        }

        if steps != 21 {
            vec_free::<i32>(stack);
            vec_free::<i32>(prog);
            return 2 as Int;
        }

        if sp != 1 {
            vec_free::<i32>(stack);
            vec_free::<i32>(prog);
            return 3 as Int;
        }

        if reg0 != 120 {
            vec_free::<i32>(stack);
            vec_free::<i32>(prog);
            return 4 as Int;
        }

        let result: i32 = top(&stack, sp);

        vec_free::<i32>(stack);
        vec_free::<i32>(prog);

        return result as Int;
    }
}
