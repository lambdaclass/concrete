// Adversarial: leaf functions with no params and no locals.
// Expected: minimum frame size (just return address = 8 bytes).

fn bare_leaf() -> i32 { return 0; }

fn another_bare() -> i32 { return 1; }

fn caller_of_bare() -> i32 {
    return bare_leaf() + another_bare();
}

fn main() -> i32 {
    let r: i32 = caller_of_bare();
    if r == 1 { return 0; }
    return 1;
}
