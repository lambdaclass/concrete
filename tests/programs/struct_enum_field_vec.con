// Regression test: struct with enum field stored in Vec.
// The enum tag must survive vec_push/vec_get correctly.

enum Copy Kind {
    A {},
    B {},
    C {},
}

struct Copy Item {
    x: Int,
    y: Int,
    kind: Kind,
}

fn main() with(Std) -> Int {
    let mut v: Vec<Item> = vec_new::<Item>();
    vec_push::<Item>(&mut v, Item { x: 0, y: 5, kind: Kind::A {} });
    vec_push::<Item>(&mut v, Item { x: 6, y: 2, kind: Kind::B {} });
    vec_push::<Item>(&mut v, Item { x: 9, y: 1, kind: Kind::C {} });

    let i0: Item = vec_get::<Item>(&v, 0);
    let i1: Item = vec_get::<Item>(&v, 1);
    let i2: Item = vec_get::<Item>(&v, 2);

    let mut r: Int = 0;
    match i0.kind {
        Kind::A {} => { r = r + 100; },
        Kind::B {} => { r = r + 200; },
        Kind::C {} => { r = r + 300; },
    }
    match i1.kind {
        Kind::A {} => { r = r + 10; },
        Kind::B {} => { r = r + 20; },
        Kind::C {} => { r = r + 30; },
    }
    match i2.kind {
        Kind::A {} => { r = r + 1; },
        Kind::B {} => { r = r + 2; },
        Kind::C {} => { r = r + 3; },
    }

    vec_free::<Item>(v);
    // Expected: 100 + 20 + 3 = 123
    return r;
}
