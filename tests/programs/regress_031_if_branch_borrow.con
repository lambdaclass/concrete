// Bug 031 shape 1 (statement if/else): a local whose address is FIRST taken
// inside a branch (here via method-call autoborrow `x.geta()` = `Box3_geta(&x)`)
// must be promoted BEFORE the branch — the lazy addrOfLocal promotion emitted
// the initializing store inside one branch only, so the sibling branch (and
// post-merge uses on that path) read an UNINITIALIZED alloca (silent garbage /
// segfault). Expected: 101 (else path: geta()=1, +100).
mod m {
    struct Box3 { a: u64, b: u64, c: u64 }
    impl Destroy for Box3 { fn destroy(&self) {} }
    impl Box3 {
        fn geta(&self) -> u64 { return self.a; }
    }
    fn cond() -> bool { return false; }
    fn main() -> Int {
        let flag: bool = cond();
        let x: Box3 = Box3 { a: 1, b: 2, c: 3 };
        let mut rc: Int = 0;
        if flag {
            let n: u64 = x.geta();
            rc = n as Int;
        } else {
            let n: u64 = x.geta();
            rc = (n as Int) + 100;
        }
        destroy(x);
        return rc;
    }
}
