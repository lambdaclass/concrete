// Basic union: fields share memory, typed as a struct with isUnion=true
union Payload {
    i: Int,
    f: Float64,
}

// Create a union and read a field in a trusted function
trusted fn read_int(p: Payload) -> Int {
    // Unions destructure whole-owner like structs (all fields bound; they
    // share memory) — this is the consume for the owned param (H17).
    let Payload { i, f } = p;
    return i;
}

fn main() with(Std) -> Int {
    let p: Payload = Payload { i: 42 };
    let result: Int = read_int(p);
    return result;
}
