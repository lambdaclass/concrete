// Pressure: Trusted/FFI boundary — libc wrapper pattern
//
// Declares trusted extern fn for basic libc functions (abs, strlen-like),
// wraps them in trusted fn wrappers, and validates results in pure code.
//
// Reveals:
//   - FFI declaration linking (do extern fns resolve against libc?)
//   - trusted/safe boundary crossing
//   - Raw pointer creation from arrays for C interop
//   - Capability propagation through trusted wrappers
//
// Expected: may fail at link time if libc symbols are not auto-linked.

// === Layer 1: FFI declarations (C standard library) ===

trusted extern fn abs(x: i32) -> i32;

// strlen takes a pointer to a null-terminated string
trusted extern fn strlen(s: *const u8) -> u64;

// memcmp compares two memory regions
trusted extern fn memcmp(s1: *const u8, s2: *const u8, n: u64) -> i32;

// === Layer 2: Trusted wrappers ===

// Wrap abs — trivial, but tests the call path
trusted fn safe_abs(x: i32) -> i32 {
    return abs(x);
}

// Wrap strlen — creates a pointer from a fixed array, calls C
trusted fn safe_strlen(buf: *const u8) -> u64 {
    return strlen(buf);
}

// Wrap memcmp — compares two buffers
trusted fn safe_memcmp(a: *const u8, b: *const u8, n: u64) -> i32 {
    return memcmp(a, b, n);
}

// === Layer 3: Pure validation (no capabilities, no trusted) ===

fn validate_abs(input: i32, result: i32) -> i32 {
    // abs should return non-negative
    if result < 0 { return 1; }
    // abs(positive) == positive
    if input > 0 {
        if result != input { return 2; }
    }
    // abs(0) == 0
    if input == 0 {
        if result != 0 { return 3; }
    }
    // abs(negative) == -negative
    if input < 0 {
        if result != (0 - input) { return 4; }
    }
    return 0;
}

fn validate_strlen(expected: u64, actual: u64) -> i32 {
    if expected == actual { return 0; }
    return 1;
}

// === Entry point ===

pub fn main() with(Console) -> Int {
    let mut failures: i32 = 0;

    // --- Test 1: abs of positive number ---
    let r1: i32 = safe_abs(42);
    let v1: i32 = validate_abs(42, r1);
    if v1 != 0 {
        println("FAIL: abs(42)");
        failures = failures + 1;
    } else {
        println("OK: abs(42)");
    }

    // --- Test 2: abs of negative number ---
    let r2: i32 = safe_abs(0 - 17);
    let v2: i32 = validate_abs(0 - 17, r2);
    if v2 != 0 {
        println("FAIL: abs(-17)");
        failures = failures + 1;
    } else {
        println("OK: abs(-17)");
    }

    // --- Test 3: abs of zero ---
    let r3: i32 = safe_abs(0);
    let v3: i32 = validate_abs(0, r3);
    if v3 != 0 {
        println("FAIL: abs(0)");
        failures = failures + 1;
    } else {
        println("OK: abs(0)");
    }

    // --- Test 4: strlen of a known null-terminated buffer ---
    // "Hello" = [72, 101, 108, 108, 111, 0]
    let buf4: [u8; 8] = [72, 101, 108, 108, 111, 0, 0, 0];
    let r4: u64 = safe_strlen(&buf4 as *const u8);
    let v4: i32 = validate_strlen(5, r4);
    if v4 != 0 {
        println("FAIL: strlen(Hello)");
        failures = failures + 1;
    } else {
        println("OK: strlen(Hello)");
    }

    // --- Test 5: strlen of empty string ---
    let buf5: [u8; 4] = [0, 0, 0, 0];
    let r5: u64 = safe_strlen(&buf5 as *const u8);
    let v5: i32 = validate_strlen(0, r5);
    if v5 != 0 {
        println("FAIL: strlen(empty)");
        failures = failures + 1;
    } else {
        println("OK: strlen(empty)");
    }

    // --- Test 6: memcmp of equal buffers ---
    let bufa: [u8; 4] = [1, 2, 3, 4];
    let bufb: [u8; 4] = [1, 2, 3, 4];
    let r6: i32 = safe_memcmp(&bufa as *const u8, &bufb as *const u8, 4);
    if r6 != 0 {
        println("FAIL: memcmp(equal)");
        failures = failures + 1;
    } else {
        println("OK: memcmp(equal)");
    }

    // --- Test 7: memcmp of different buffers ---
    let bufc: [u8; 4] = [1, 2, 3, 5];
    let r7: i32 = safe_memcmp(&bufa as *const u8, &bufc as *const u8, 4);
    if r7 == 0 {
        println("FAIL: memcmp(different) returned 0");
        failures = failures + 1;
    } else {
        println("OK: memcmp(different)");
    }

    // --- Summary ---
    if failures == 0 {
        println("All 7 libc wrapper tests passed.");
    } else {
        print(failures as Int);
        println(" test(s) failed.");
    }

    return failures as Int;
}
