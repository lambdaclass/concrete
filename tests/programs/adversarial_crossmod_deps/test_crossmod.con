// Cross-module dependency identity test.
// Two modules each have a function named "add" — proved via registry.
// A caller in one module uses "add" from the same module.
// The dependency must use the correct qualified name.

mod left {
    #[spec(left_add_spec)]
    #[proof_by(Concrete.Proof.left_add_correct)]
    #[proof_fingerprint("de2a547f92ade3a8659292ab6adf0eef")]
    pub fn add(a: i64, b: i64) -> i64 {
        return a + b;
    }

    pub fn use_add(x: i64) -> i64 {
        return add(x, 1);
    }
}

mod right {
    #[spec(right_add_spec)]
    #[proof_by(Concrete.Proof.right_add_correct)]
    #[proof_fingerprint("de2a547f92ade3a8659292ab6adf0eef")]
    pub fn add(a: i64, b: i64) -> i64 {
        return a + b;
    }

    pub fn use_add(x: i64) -> i64 {
        return add(x, 2);
    }
}

fn main() -> i64 {
    let a: i64 = left::use_add(10);
    let b: i64 = right::use_add(20);
    return a + b;
}
