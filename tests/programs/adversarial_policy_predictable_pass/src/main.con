// Adversarial boundary: predictable = true but code is fully predictable.
// No recursion, no unbounded loops, no allocation, no FFI, no blocking I/O.
// Expected: compiler accepts — pure bounded computation is allowed.

pub fn add(a: Int, b: Int) -> Int {
    return a + b;
}

pub fn main() -> Int {
    // exit-code semantics: 0 = success; the value is checked, not echoed
    if add(20, 22) != 42 { return 1; }
    return 0;
}
