// Adversarial: spec-drift gate (regression for commit f371cc1).
//
// `simple_add` here has its source body matching the in-source
// `#[proof_fingerprint]` (so the fingerprint staleness check does NOT
// fire).  The linked spec
// `Concrete.Proof.driftTestSpec`, however, evaluates to a PExpr
// that does NOT match the source-extracted PExpr.
//
// The spec-drift gate must:
//   1. Detect the mismatch — produce a `specDrift` registry
//      issue with the exact diagnostic substring.
//   2. Downgrade the obligation status from `proved` to `stale`.
//
// Tested by scripts/tests/run_tests.sh — search "spec_drift".
//
// This is a CHECKED-IN broken state on purpose.  Do not "fix"
// driftTestSpec to match the source; that defeats the gate.

mod test_drift {

    // The #[proof_fingerprint] MATCHES the current body, so the staleness check
    // does NOT fire — but the linked #[spec] driftTestSpec evaluates to a PExpr
    // that does not match the source-extracted one, so the spec-drift gate
    // downgrades this from proved to stale. (Checked-in broken state on purpose.)
    #[spec(Concrete.Proof.driftTestSpec)]
    #[proof_by(Concrete.Proof.drift_test_theorem)]
    #[proof_fingerprint("9671eeae7fddc0cd")]
    fn simple_add(a: i32, b: i32) -> i32 {
        return a + b;
    }

    pub fn main() -> i32 {
        let _: i32 = simple_add(1, 2);
        return 0;
    }
}
