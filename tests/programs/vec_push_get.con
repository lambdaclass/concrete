// Test: push/get at various indices
fn main() with(Std) -> Int {
    let mut v: Vec<Int> = vec_new::<Int>();
    vec_push(&mut v, 100);
    vec_push(&mut v, 200);
    vec_push(&mut v, 300);
    vec_push(&mut v, 400);
    let first: Int = vec_get(&v, 0);
    let last: Int = vec_get(&v, 3);
    vec_free(v);
    return first + last;
}
