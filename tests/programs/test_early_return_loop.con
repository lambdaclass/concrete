// Test: early return from inside a nested loop
fn find_sum() -> Int {
    let mut i: Int = 0;
    while i < 100 {
        let mut j: Int = 0;
        while j < 100 {
            if i == 6 {
                if j == 7 {
                    return i * j;
                }
            }
            j = j + 1;
        }
        i = i + 1;
    }
    return 0;
}

fn main() -> Int {
    return find_sum();
}
