// One branch consumes borrow-block ref, other doesn't.
// Expected error: branch disagreement on consumption

fn increment(x: &mut Int) {
    *x = *x + 1;
}

fn main() -> Int {
    let mut n: Int = 10;
    let cond: Bool = true;
    borrow mut n as r in R {
        if cond {
            increment(r);
        } else {
            *r = *r - 5;
        }
    }
    return n;
}
