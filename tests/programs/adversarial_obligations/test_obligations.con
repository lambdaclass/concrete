// Test program for mechanical obligation generation.
// Exercises all 5 obligation statuses: proved, stale, missing, ineligible, trusted.

#[spec(add_commutativity)]
#[proof_by(Concrete.Proof.pure_add_correct)]
#[proof_fingerprint("9671eeae7fddc0cd")]
fn pure_add(a: i64, b: i64) -> i64 {
    return a + b;
}

// STALE: #[proof_fingerprint] is the hash of an old body, so it no longer matches.
#[spec(sub_identity)]
#[proof_by(Concrete.Proof.pure_sub_correct)]
#[proof_fingerprint("d4ec801267181540")]
fn pure_stale(a: i64, b: i64) -> i64 {
    return a - b;
}

fn pure_no_spec(a: i64, b: i64) -> i64 {
    return a * b;
}

fn uses_alloc(n: i64) with(Alloc) -> i64 {
    return n + 1;
}

trusted fn trusted_op(x: i64) -> i64 {
    return x + 1;
}

fn main() -> i64 {
    let x: i64 = pure_add(1, 2);
    let y: i64 = pure_stale(3, 4);
    let w: i64 = pure_no_spec(5, 6);
    let z: i64 = trusted_op(x);
    return y + z + w;
}
