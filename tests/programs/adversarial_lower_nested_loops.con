// Adversarial lowering: 4 levels of nested for-loops.
// Stresses loop lowering, phi node generation, and nested induction variables.
// Expected: 42

fn nested_sum() -> Int {
    let mut total: Int = 0;
    for (let mut i: Int = 0; i < 3; i = i + 1) {
        for (let mut j: Int = 0; j < 3; j = j + 1) {
            for (let mut k: Int = 0; k < 3; k = k + 1) {
                total = total + 1;
            }
        }
    }
    // 3*3*3 = 27
    return total;
}

fn nested_product() -> Int {
    let mut total: Int = 0;
    for (let mut i: Int = 0; i < 3; i = i + 1) {
        for (let mut j: Int = 0; j < 5; j = j + 1) {
            total = total + 1;
        }
    }
    // 3*5 = 15
    return total;
}

pub fn main() -> Int {
    // 27 + 15 = 42
    return nested_sum() + nested_product();
}
