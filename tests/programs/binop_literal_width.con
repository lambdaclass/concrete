// Oracle regression (found by scripts/tests/fuzz_differential.py): a binop where
// one side is a COMPOUND literal expression (default `int`/i64, e.g. `8 + 5`) and
// the other is a concrete `i32` value must coerce the literal side to the concrete
// width. Previously only a BARE literal coerced, so `(8 + 5) + v1` stayed
// `int + i32` and codegen emitted a mismatched-operand binop (E0715). Expected: 32
// ((8+5)+3=16, plus s.x*... — see below; deterministic).
mod m {
    struct Copy P { x: i32, y: i32 }
    fn main() -> Int {
        let v1: i32 = 3;
        let s: P = P { x: 4, y: 5 };
        // compound-literal + i32 var, and compound-literal + i32 field, in a
        // hint-free (comparison) position — the case that broke.
        let a: i32 = (8 + 5) + v1;                 // 16
        let mut r: i32 = a;
        if ((2 + 2) + s.x) > 0 { r = r + ((1 + 1) + s.y); }  // cond true; +7 -> 23
        return (r + ((3 + 6) % 1000)) as Int;       // 23 + 9 = 32
    }
}
