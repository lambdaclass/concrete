// Chain of Option operations: tests Result/Option ergonomics
fn safe_div(a: Int, b: Int) -> Option<Int> {
    if b == 0 {
        return Option::None {};
    } else {
        return Option::Some { value: a / b };
    }
}

fn unwrap_or(opt: Option<Int>, default: Int) -> Int {
    match opt {
        Option::Some { value } => { return value; },
        Option::None {} => { return default; },
    }
}

fn main() with(Std) -> Int {
    let r1: Option<Int> = safe_div(100, 5);
    let r2: Option<Int> = safe_div(100, 0);
    let r3: Option<Int> = safe_div(42, 7);
    let v1: Int = unwrap_or(r1, 0);
    let v2: Int = unwrap_or(r2, 0);
    let v3: Int = unwrap_or(r3, 0);
    return v1 + v2 + v3;
}
