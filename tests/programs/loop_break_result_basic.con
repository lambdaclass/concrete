// Migration of the removed value `while … else` (Phase 6D item 2): the loop
// result is a mutable variable assigned before `break;`. Replaces
// while_expr_basic.con with identical behavior. Expected: 5
fn main() -> Int {
    let mut i: Int = 0;
    let mut x: Int = 0;
    while i < 10 {
        i = i + 1;
        if i == 5 {
            x = i;
            break;
        }
    }
    return x;
}
