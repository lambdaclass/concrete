// Conditional Copy (Phase 7 #3): a declared-Copy generic is Copy iff every
// field/payload is Copy after substitution. Option<i32>, Result<i32, i32>, and
// a Copy-marked Box<i32> behave as Copy: reusable, `_`-ignorable, if-let-able.
// Expected: 37
struct Copy Box<T> { val: T }

fn main() -> Int {
    // Option<i32> is Copy: match twice, wildcard-ignore legally
    let o: Option<i32> = Option::Some { value: 4 };
    let a: i32 = match o { Option::Some { value } => value, Option::None => 0 };
    let b: i32 = match o { Option::Some { value } => value, Option::None => 0 };
    let w: i32 = match o { _ => 1 };   // `_` may ignore a Copy value (E0288 gates non-Copy)

    // if-let over Option<i32> is now legal for the right reason: the desugared
    // catch-all `_` discards a genuinely Copy value (was E0288 pre-conditional-Copy)
    let mut g: i32 = 0;
    if let Option::Some { value } = o { g = value; }

    // Result<i32, i32> is Copy
    let r: Result<i32, i32> = Result::Ok { value: 5 };
    let c: i32 = match r { Result::Ok { value } => value, Result::Err { error } => error };
    let d: i32 = match r { Result::Ok { value } => value, Result::Err { error } => error };

    // Copy-marked generic Box<i32> is Copy: by-value field read is a legal Copy read
    let bx: Box<i32> = Box::<i32> { val: 7 };
    let e: i32 = bx.val;
    let f: i32 = bx.val;

    return (a + b + w + c + d + e + f + g) as Int;   // 4+4+1+5+5+7+7+4 = 37
}
