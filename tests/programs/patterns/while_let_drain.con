// Pattern: `while let` loops while the scrutinee matches, re-evaluating it each
// iteration; the non-matching case ends the loop. Copy scrutinee (the desugared
// `_ => break` arm discards it; `_` may discard only Copy data). Sum 3+2+1 = 6.
// Expected: 6
mod m {
    enum Copy OptI { Some { value: i32 }, None {} }
    fn next_val(n: i32) -> OptI {
        if n > 0 { return OptI::Some { value: n }; }
        return OptI::None {};
    }
    fn main() -> Int {
        let mut i: i32 = 3;
        let mut sum: i32 = 0;
        while let OptI::Some { value } = next_val(i) {
            sum = sum + value;
            i = i - 1;
        }
        return sum as Int;
    }
}
