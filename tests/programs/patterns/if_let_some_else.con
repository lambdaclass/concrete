// Pattern: `if let` binds on match, else runs otherwise. The scrutinee enum is
// Copy: the desugared catch-all `_` arm discards the no-match value, and `_`
// may discard only Copy data (linear rule; see neg_if_let_noncopy for the
// non-Copy rejection). Expected: 7
mod m {
    enum Copy OptI { Some { value: i32 }, None {} }
    fn unwrap_or(o: OptI, d: i32) -> i32 {
        if let OptI::Some { value } = o { return value; } else { return d; }
    }
    fn main() -> Int {
        let s: OptI = OptI::Some { value: 7 };
        let n: OptI = OptI::None {};
        if unwrap_or(s, 99) == 7 && unwrap_or(n, 0) == 0 { return 7; }
        return 1;
    }
}
