// Adversarial: one function with a bounded for-loop, another with while(true).
// The bounded function should pass predictable; the unbounded one should fail.
//
// Expected:
//   count_up  — bounded loops, passes predictable
//   spin      — unbounded loops, fails predictable

fn count_up(n: Int) -> Int {
    let mut total: Int = 0;
    for (let mut i: Int = 0; i < n; i = i + 1) {
        total = total + i;
    }
    return total;
}

fn spin() -> Int {
    let mut x: Int = 0;
    while true {
        x = x + 1;
    }
    return x;
}

pub fn main() -> Int {
    return count_up(10);
}
