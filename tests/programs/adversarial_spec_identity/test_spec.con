// Test program for spec identity tests.
// Used with in-source proof links to verify spec attachment flows through ProofCore.

#[spec(add_commutativity)]
#[proof_by(Concrete.Proof.pure_add_correct)]
#[proof_fingerprint("de2a547f92ade3a8659292ab6adf0eef")]
fn pure_add(a: i64, b: i64) -> i64 {
    return a + b;
}

#[spec(mul_associativity)]
#[proof_by(Concrete.Proof.pure_mul_correct)]
#[proof_fingerprint("6f1cd1a45b382ac146ff3d2a785ffbfc")]
fn pure_mul(a: i64, b: i64) -> i64 {
    return a * b;
}

fn main() -> i64 {
    let x: i64 = pure_add(1, 2);
    let y: i64 = pure_mul(3, 4);
    return x + y;
}
