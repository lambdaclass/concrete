// Loop control: C-style `for` with both `continue` (skip i==2) and `break`
// (stop at i==5). Sum of 0,1,3,4 = 8. Expected: 8
mod m {
    fn main() -> Int {
        let mut s: i32 = 0;
        for (let mut i: i32 = 0; i < 100; i = i + 1) {
            if i == 5 { break; }
            if i == 2 { continue; }
            s = s + i;
        }
        return s as Int;
    }
}
