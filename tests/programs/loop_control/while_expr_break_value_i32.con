// Loop control: while-as-expression with a typed `break <value>` at a non-i64
// width. Regression for the width bug where the break/else value was stored as
// i64 into an i32 result slot (load i32 -> 0). Expected: 7
mod m {
    fn main() -> Int {
        let mut i: i32 = 0;
        let v: i32 = while i < 10 {
            if i == 3 { break 7; }
            i = i + 1;
        } else {
            0
        };
        return v as Int;
    }
}
