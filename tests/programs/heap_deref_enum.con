// *heap_ptr on enum, then match
enum Shape {
    Circle { radius: Int },
    Rect { w: Int, h: Int }
}

fn main() with(Std) -> Int {
    let hs: Heap<Shape> = alloc(Shape::Circle { radius: 21 });
    let s: Shape = *hs;
    match s {
        Shape::Circle { radius } => {
            return radius * 2;
        },
        Shape::Rect { w, h } => {
            return w + h;
        },
    }
}
