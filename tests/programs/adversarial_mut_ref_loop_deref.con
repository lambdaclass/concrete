// Deref read/write inside a loop is fine — not consumption.
// Borrow-block ref from outer scope used via deref in loop.

fn main() -> Int {
    let mut n: Int = 0;
    borrow mut n as r in R {
        let mut i: Int = 0;
        while i < 5 {
            *r = *r + 1;
            i = i + 1;
        }
    }
    return n;
}
