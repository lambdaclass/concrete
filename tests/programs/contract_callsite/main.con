// Fixture for call-site contract obligations + discharge backends.
// `concrete tests/programs/contract_callsite/main.con --report contracts`
// shows every discharge state for calls into a #[requires]-bearing fn:
//   good     -> proved_at_callsite        (rotr(x, 13): literal, constant-folded)
//   letgood  -> proved_by_kernel_decision (rotr(x, n) with let n=7: closed after
//                                          let-subst, checked by bv_decide)
//   bad      -> failed_at_callsite        (rotr(x, 40): 40 < 32 is false)
//   letbad   -> failed_at_callsite        (let n=40: closed and violated)
//   unknown  -> unproven_at_callsite      (rotr(x, k): non-constant, no backend)
mod demo {
    spec fn rotr_spec(x: u32, n: u32) -> u32;

    #[requires(0 <= n && n < 32)]
    #[ensures(result == rotr_spec(x, n))]
    fn rotr(x: u32, n: u32) -> u32 {
        return (x >> n) | (x << (32 - n));
    }

    fn good(x: u32) -> u32 { return rotr(x, 13); }
    fn letgood(x: u32) -> u32 { let n: u32 = 7; return rotr(x, n); }
    fn bad(x: u32) -> u32 { return rotr(x, 40); }
    fn letbad(x: u32) -> u32 { let n: u32 = 40; return rotr(x, n); }
    fn unknown(x: u32, k: u32) -> u32 { return rotr(x, k); }
}

pub fn main() with(Std) -> Int { return 0; }
