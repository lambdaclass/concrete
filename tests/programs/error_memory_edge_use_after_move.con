// ERROR TEST: use after move — must be rejected.

struct Resource {
    id: Int,
}

fn consume_resource(r: Resource) -> Int {
    return r.id;
}

fn bad_double_use() -> Int {
    let r: Resource = Resource { id: 1 };
    let _x: Int = consume_resource(r);
    let _y: Int = consume_resource(r);
    return 0;
}

fn main() -> Int {
    return bad_double_use();
}
