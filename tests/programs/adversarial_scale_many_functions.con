// Hostile workload: 40 functions in a single file.
// Stresses name resolution, report generation, and function table scaling.
// Each function calls the next in a chain.
// Expected: 42

fn f01(x: Int) -> Int { return x + 1; }
fn f02(x: Int) -> Int { return f01(x) + 1; }
fn f03(x: Int) -> Int { return f02(x) + 1; }
fn f04(x: Int) -> Int { return f03(x) + 1; }
