fn f38(x: Int) -> Int { return f37(x) + 1; }
fn f39(x: Int) -> Int { return f38(x) + 1; }
fn f40(x: Int) -> Int { return f39(x) + 1; }

// f40(2) = 2 + 40 = 42
pub fn main() -> Int {
    return f40(2);
}
