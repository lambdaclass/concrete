// Adversarial lowering: array of structs with loop iteration.
// Stresses GEP for array-of-aggregate indexing and struct field extraction.
// Expected: 42

struct Copy Point { x: Int, y: Int }

fn sum_points(pts: [Point; 4]) -> Int {
    let mut acc: Int = 0;
    for (let mut i: Int = 0; i < 4; i = i + 1) {
        acc = acc + pts[i].x + pts[i].y;
    }
    return acc;
}

pub fn main() -> Int {
    let pts: [Point; 4] = [
        Point { x: 1, y: 2 },
        Point { x: 3, y: 4 },
        Point { x: 5, y: 6 },
        Point { x: 7, y: 14 },
    ];
    // 1+2+3+4+5+6+7+14 = 42
    return sum_points(pts);
}
