enum Shape { Circle { radius: Int }, Rect { w: Int, h: Int } }

fn area(s: Shape) -> Int {
    match s {
        Shape::Circle { radius } => { return radius * radius; },
        Shape::Rect { w, h } => { return w * h; },
    }
}

fn main() with(Console) {
    let s: Shape = Shape::Rect { w: 3, h: 4 };
    println((area(s)));
}
