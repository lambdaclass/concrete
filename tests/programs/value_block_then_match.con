// Oracle regression (found by scripts/tests/fuzz_differential.py): a value-bearing
// `if`/`match` block sets the internal `__last_expr` pseudo-variable; it must not
// leak into a later construct's merge/loop phi reconciliation. Previously a
// preceding if-EXPRESSION made the next `match` (or loop) build a spurious,
// mistyped/non-dominated phi for `__last_expr` (E0708/E0710/E0715). Fixed by
// dropping `__last_expr` from `snapshotVars`. Expected: 12.
mod m {
    struct Copy P { x: i32, y: i32 }
    enum Copy E { A { v: i32 }, B { w: i32 }, C {} }
    fn main() -> Int {
        let mut a: i32 = 0;
        let s: P = P { x: 2, y: 2 };
        let e0: E = E::A { v: 7 };
        a = if 1 > 0 { 5 } else { 4 };                 // if-expr sets __last_expr
        let b: i32 = match e0 {                          // next match must not inherit it
            E::A { v } => v,                             // 7
            E::B { w } => w,
            E::C {} => s.x
        };
        let c: i32 = if a > 0 { 0 } else { 9 };         // if-expr after match too
        return (a + b + c) as Int;                       // 5 + 7 + 0 = 12
    }
}
