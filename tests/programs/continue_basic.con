// Test basic continue in while loop - skip even numbers
// Expected: 25 (sum of odd numbers 1+3+5+7+9)

fn main() with(Std) -> Int {
    let mut sum: Int = 0;
    let mut i: Int = 0;
    while i < 10 {
        i = i + 1;
        if i % 2 == 0 {
            continue;
        }
        sum = sum + i;
    }
    return sum;
}
