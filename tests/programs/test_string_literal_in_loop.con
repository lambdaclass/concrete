// Test: string literals inside loops must be properly materialized.
// Previously produced invalid LLVM IR: store %struct.String @global, ptr %ssa
fn main() with(Std) -> Int {
    let mut strings: Vec<String> = vec_new::<String>();
    let mut i: Int = 0;
    while i < 5 {
        let s: String = "hello";
        vec_push::<String>(&mut strings, s);
        i = i + 1;
    }
    let slen: Int = vec_len::<String>(&mut strings) as Int;
    let mut si: Int = 0;
    while si < slen {
        let s: String = vec_get::<String>(&mut strings, si);
        drop_string(s);
        si = si + 1;
    }
    vec_free::<String>(strings);
    return slen;
}
