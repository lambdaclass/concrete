// Test: struct with 8+ fields passed to and returned from a function
struct Copy Big {
    a: Int,
    b: Int,
    c: Int,
    d: Int,
    e: Int,
    f: Int,
    g: Int,
    h: Int,
    i: Int,
    j: Int,
}

fn sum_big(s: Big) -> Int {
    return s.a + s.b + s.c + s.d + s.e + s.f + s.g + s.h + s.i + s.j;
}

fn make_big() -> Big {
    return Big { a: 1, b: 2, c: 3, d: 4, e: 5, f: 6, g: 7, h: 8, i: 3, j: 3 };
}

fn main() -> Int {
    let s: Big = make_big();
    return sum_big(s);
}
