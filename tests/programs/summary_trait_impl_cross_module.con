mod Lib {
    pub struct Point { x: Int, y: Int }
    pub trait Summable {
        fn total(&self) -> Int;
    }
    impl Summable for Point {
        fn total(&self) -> Int { return self.x + self.y; }
    }
    fn consume(p: Point) -> Int {
        let Point { x, y } = p; return x + y; }
    pub fn make_and_sum(x: Int, y: Int) -> Int {
        let p: Point = Point { x: x, y: y };
        let result: Int = p.total();
        match consume(p) { _ => {} }        return result;
    }
}
mod Main {
    import Lib.{ make_and_sum };
    fn main() -> Int { return make_and_sum(12, 30); }
}
