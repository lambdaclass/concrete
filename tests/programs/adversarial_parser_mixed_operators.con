// Adversarial parser: complex expression with mixed arithmetic, comparison,
// and logical operators testing precedence correctness.
// Expected: 42

fn check(a: Int, b: Int, c: Int) -> Int {
    // Test precedence: * before +, comparisons, logical
    let arith: Int = a * 2 + b * 3 + c;
    let cmp1: Int = if a + b > c { 1 } else { 0 };
    let cmp2: Int = if a * b <= c + 10 { 1 } else { 0 };
    let cmp3: Int = if a != b { 1 } else { 0 };
    return arith + cmp1 + cmp2 + cmp3;
}

pub fn main() -> Int {
    // check(3, 5, 7): arith = 6+15+7 = 28, cmp1 = (8>7)=1, cmp2 = (15<=17)=1, cmp3 = (3!=5)=1
    // total = 28 + 1 + 1 + 1 = 31
    let a: Int = check(3, 5, 7);
    // check(2, 1, 3): arith = 4+3+3 = 10, cmp1 = (3>3)=0, cmp2 = (2<=13)=1, cmp3 = (2!=1)=1
    // total = 10 + 0 + 1 + 1 = 12
    let b: Int = check(2, 1, 3);
    // 31 + 12 = 43... adjust: check(2, 1, 2): arith = 4+3+2=9, cmp1=(3>2)=1, cmp2=(2<=12)=1, cmp3=1 => 12
    // 31+12=43. Try check(3,5,6): arith=6+15+6=27, cmp1=(8>6)=1, cmp2=(15<=16)=1, cmp3=1 => 30
    // 30+12=42. Yes!
    let c: Int = check(3, 5, 6);
    let d: Int = check(2, 1, 3);
    return c + d;
}
