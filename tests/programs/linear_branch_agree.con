struct Resource {
    value: Int,
}

fn consume(r: Resource) -> Int {
    let Resource { value } = r;
    return value;
}

fn main() with(Console) {
    let r: Resource = Resource { value: 42 };
    let mut result: Int = 0;
    if true {
        result = consume(r);
    } else {
        result = consume(r);
    }
    println((result));
}
