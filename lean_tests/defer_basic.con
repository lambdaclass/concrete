// Test: defer runs cleanup at scope exit
struct Resource { value: Int }

impl Destroy for Resource {
    fn destroy(&self) {
        // cleanup happens here
    }
}

fn use_resource() -> Int {
    let mut r: Resource = Resource { value: 10 };
    defer destroy(r);
    return r.value;
}

fn main() -> Int {
    let result: Int = use_resource();
    return result;
}
