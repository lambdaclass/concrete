// Test: call method on Heap<T> value
// Expected: 30
struct Point {
    x: Int,
    y: Int,
}

impl Point {
    fn sum(&self) -> Int {
        return self.x + self.y;
    }
}

fn main() with(Std) -> Int {
    let p: Heap<Point> = alloc(Point { x: 10, y: 20 });
    let result: Int = p->x + p->y;
    free(p);
    return result;
}
