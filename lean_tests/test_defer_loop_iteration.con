// Test: defer inside a loop body runs at the end of each iteration.
// Each iteration allocates a string, defers its cleanup, and the
// deferred drop runs before the next iteration starts.
fn work() with(Console, Alloc) -> i32 {
    let mut i: i32 = 0;
    while i < 3 {
        let s: String = "x";
        defer drop_string(s);
        print_string(&s);
        i = i + 1;
    }
    print_char(10);
    return i;
}

fn main() with(Std) -> Int {
    return work() as Int;
}
