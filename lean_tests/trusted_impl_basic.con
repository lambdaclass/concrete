// Trusted impl methods can do pointer casts without with(Unsafe) — compiles successfully
struct Wrapper {
    value: i32,
}

trusted impl Wrapper {
    fn cast_ref(p: *const i32) -> *const u8 {
        let q: *const u8 = p as *const u8;
        return q;
    }
}

fn main() -> i32 {
    return 0;
}
