// Error: match that doesn't cover all enum variants
enum Direction { North {}, South {}, East {}, West {} }

fn go(d: Direction) -> Int {
    match d {
        Direction#North {} => { return 1; },
        Direction#South {} => { return 2; },
    }
}

fn main() -> Int {
    let d: Direction = Direction#West {};
    return go(d);
}
