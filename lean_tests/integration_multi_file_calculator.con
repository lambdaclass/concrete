// Integration test: multi-module calculator with expression tree evaluation.
//
// Exercises:
// - Cross-module function calls across 3 modules
// - Vec as a data structure (postfix bytecode + evaluation stack)
// - Trait dispatch (Describable trait + generic compute_complexity)
// - While loops, function call chains across modules
// - vec_set for proper stack push/pop semantics
// - Capability propagation through module boundaries
// - Multiple expressions evaluated and checksummed
//
// Architecture:
//   mod Metrics — Describable trait, generic complexity computation
//   mod Eval   — stack-based RPN evaluation using Vec<i32>
//   mod Main   — build expressions, evaluate, analyze, verify checksum
//
// Bytecode encoding: tag 0 = Lit (next i32 is value), 1 = Add, 2 = Sub, 3 = Mul
//
// Expected output: 42

mod Eval {
    fn stack_push(stack: &mut Vec<i32>, sp: &mut i32, val: i32) with(Alloc) {
        let idx: Int = *sp as Int;
        if idx >= vec_len::<i32>(stack) {
            vec_push::<i32>(stack, val);
        } else {
            vec_set::<i32>(stack, idx, val);
        }
        *sp = *sp + 1;
    }

    fn stack_pop(stack: &Vec<i32>, sp: &mut i32) -> i32 {
        *sp = *sp - 1;
        return vec_get::<i32>(stack, (*sp) as Int);
    }

    pub fn evaluate(program: &Vec<i32>, prog_len: i32) with(Alloc) -> i32 {
        let mut stack: Vec<i32> = vec_new::<i32>();
        let mut sp: i32 = 0;
        let len: i32 = prog_len;
        let mut i: i32 = 0;

        while i < len {
            let tag: i32 = vec_get::<i32>(program, i as Int);
            if tag == 0 {
                i = i + 1;
                let val: i32 = vec_get::<i32>(program, i as Int);
                stack_push(&mut stack, &mut sp, val);
            } else if tag == 1 {
                let a: i32 = stack_pop(&stack, &mut sp);
                let b: i32 = stack_pop(&stack, &mut sp);
                stack_push(&mut stack, &mut sp, b + a);
            } else if tag == 2 {
                let a: i32 = stack_pop(&stack, &mut sp);
                let b: i32 = stack_pop(&stack, &mut sp);
                stack_push(&mut stack, &mut sp, b - a);
            } else {
                let a: i32 = stack_pop(&stack, &mut sp);
                let b: i32 = stack_pop(&stack, &mut sp);
                stack_push(&mut stack, &mut sp, b * a);
            }
            i = i + 1;
        }

        let result: i32 = vec_get::<i32>(&stack, (sp - 1) as Int);
        vec_free::<i32>(stack);
        return result;
    }
}

mod Main {
    import Eval.{ evaluate };

    // Trait for complexity metrics
    trait Describable {
        fn complexity(&self) -> i32;
    }

    struct Copy ExprStats {
        num_ops: i32,
        num_lits: i32,
    }

    impl Describable for ExprStats {
        fn complexity(&self) -> i32 {
            return self.num_ops * 2 + self.num_lits;
        }
    }

    fn compute_complexity<T: Describable>(item: &T) -> i32 {
        return item.complexity();
    }

    fn analyze(program: &Vec<i32>, prog_len: i32) -> ExprStats {
        let mut ops: i32 = 0;
        let mut lits: i32 = 0;
        let mut i: i32 = 0;
        while i < prog_len {
            let tag: i32 = vec_get::<i32>(program, i as Int);
            if tag == 0 {
                lits = lits + 1;
                i = i + 2;
            } else {
                ops = ops + 1;
                i = i + 1;
            }
        }
        return ExprStats { num_ops: ops, num_lits: lits };
    }

    // Expression 1: (3 + 4) * (10 - 2) = 7 * 8 = 56
    fn build_expr1(p: &mut Vec<i32>) with(Alloc) -> i32 {
        vec_push::<i32>(p, 0); vec_push::<i32>(p, 3);
        vec_push::<i32>(p, 0); vec_push::<i32>(p, 4);
        vec_push::<i32>(p, 1);
        vec_push::<i32>(p, 0); vec_push::<i32>(p, 10);
        vec_push::<i32>(p, 0); vec_push::<i32>(p, 2);
        vec_push::<i32>(p, 2);
        vec_push::<i32>(p, 3);
        return 11;
    }

    // Expression 2: 5 + 9 = 14
    fn build_expr2(p: &mut Vec<i32>) with(Alloc) -> i32 {
        vec_push::<i32>(p, 0); vec_push::<i32>(p, 5);
        vec_push::<i32>(p, 0); vec_push::<i32>(p, 9);
        vec_push::<i32>(p, 1);
        return 5;
    }

    // Expression 3: (6 * 7) - (2 * 3) + 4 = 42 - 6 + 4 = 40
    fn build_expr3(p: &mut Vec<i32>) with(Alloc) -> i32 {
        vec_push::<i32>(p, 0); vec_push::<i32>(p, 6);   // 2
        vec_push::<i32>(p, 0); vec_push::<i32>(p, 7);   // 4
        vec_push::<i32>(p, 3);                            // 5
        vec_push::<i32>(p, 0); vec_push::<i32>(p, 2);   // 7
        vec_push::<i32>(p, 0); vec_push::<i32>(p, 3);   // 9
        vec_push::<i32>(p, 3);                            // 10
        vec_push::<i32>(p, 2);                            // 11
        vec_push::<i32>(p, 0); vec_push::<i32>(p, 4);   // 13
        vec_push::<i32>(p, 1);                            // 14
        return 14;
    }

    // Expression 4: 2 * (3 + 8) = 2 * 11 = 22
    fn build_expr4(p: &mut Vec<i32>) with(Alloc) -> i32 {
        vec_push::<i32>(p, 0); vec_push::<i32>(p, 2);
        vec_push::<i32>(p, 0); vec_push::<i32>(p, 3);
        vec_push::<i32>(p, 0); vec_push::<i32>(p, 8);
        vec_push::<i32>(p, 1);
        vec_push::<i32>(p, 3);
        return 8;
    }

    fn main() with(Std) -> Int {
        // Expression 1: (3 + 4) * (10 - 2) = 56
        let mut prog1: Vec<i32> = vec_new::<i32>();
        let len1: i32 = build_expr1(&mut prog1);
        let r1: i32 = evaluate(&prog1, len1);
        if r1 != 56 { vec_free::<i32>(prog1); return 1; }

        // Analyze: 4 lits, 3 ops, complexity = 10
        let stats1: ExprStats = analyze(&prog1, len1);
        if stats1.num_lits != 4 { vec_free::<i32>(prog1); return 2; }
        if stats1.num_ops != 3 { vec_free::<i32>(prog1); return 3; }
        let c1: i32 = compute_complexity::<ExprStats>(&stats1);
        if c1 != 10 { vec_free::<i32>(prog1); return 4; }
        vec_free::<i32>(prog1);

        // Expression 2: 5 + 9 = 14
        let mut prog2: Vec<i32> = vec_new::<i32>();
        let len2: i32 = build_expr2(&mut prog2);
        let r2: i32 = evaluate(&prog2, len2);
        if r2 != 14 { vec_free::<i32>(prog2); return 5; }
        vec_free::<i32>(prog2);

        // Expression 3: (6*7) - (2*3) + 4 = 40
        let mut prog3: Vec<i32> = vec_new::<i32>();
        let len3: i32 = build_expr3(&mut prog3);
        let r3: i32 = evaluate(&prog3, len3);
        if r3 != 40 { vec_free::<i32>(prog3); return 6; }
        vec_free::<i32>(prog3);

        // Expression 4: 2 * (3 + 8) = 22
        let mut prog4: Vec<i32> = vec_new::<i32>();
        let len4: i32 = build_expr4(&mut prog4);
        let r4: i32 = evaluate(&prog4, len4);
        if r4 != 22 { vec_free::<i32>(prog4); return 7; }
        vec_free::<i32>(prog4);

        // Checksums
        let checksum: i32 = r1 - r3 + r2 + 12;  // 56-40+14+12 = 42
        if checksum != 42 { return 8; }
        let check2: i32 = r4 + r2 + 6;  // 22+14+6 = 42
        if check2 != 42 { return 9; }

        return checksum as Int;
    }
}
