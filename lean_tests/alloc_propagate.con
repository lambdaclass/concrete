// Test: allocator capability propagates through function calls
struct Point { x: Int, y: Int }

fn make_point(x: Int, y: Int) with(Alloc) -> Heap<Point> {
    return alloc(Point { x: x, y: y });
}

fn main() with(Std) -> Int {
    let p: Heap<Point> = make_point(10, 20);
    let result: Int = p->x + p->y;
    free(p);
    return result;
}
