// Option chaining: try first, fall back to second, then default
fn first_or(a: Option<Int>, default: Int) -> Int {
    match a {
        Option#Some { value } => { return value; },
        Option#None {} => { return default; },
    }
}

fn main() with(Std) -> Int {
    let a: Option<Int> = Option#None {};
    let b: Option<Int> = Option#Some { value: 42 };
    let r1: Int = first_or(a, 0);
    let r2: Int = first_or(b, 0);
    return r1 + r2;
}
