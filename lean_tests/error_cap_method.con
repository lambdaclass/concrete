// Calling a method with capabilities from a pure function
struct Logger { level: Int }

impl Logger {
    fn log(&self) with(File) -> Int {
        return self.level;
    }
}

fn consume_logger(l: Logger) -> Int {
    return l.level;
}

fn pure_fn() -> Int {
    let l: Logger = Logger { level: 5 };
    let v: Int = l.log();
    let dummy: Int = consume_logger(l);
    return v;
}

fn main() -> Int {
    return 0;
}
