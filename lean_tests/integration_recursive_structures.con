// Integration test: recursive algorithms with complex data flow.
//
// Implements a simple expression evaluator using enums and pattern matching,
// plus a stack-based computation engine.
//
// Exercises:
// - Enum variants with varying payloads
// - Deep pattern matching
// - Recursive-style evaluation (unrolled via sequential calls)
// - While loops processing sequences of operations
// - Struct mutation through loops
// - Multiple function call layers
//
// Expected output: 42

// --- Expression representation ---
// Since we can't have recursive enums on the stack, we represent
// expressions as flat operations that build up a result.

pub enum Copy Op {
    Lit { val: i32 },
    Add { a: i32, b: i32 },
    Mul { a: i32, b: i32 },
    Neg { val: i32 },
    Sub { a: i32, b: i32 },
}

// --- Evaluate a single operation ---

fn eval_op(op: &Op) -> i32 {
    match *op {
        Op#Lit { val } => { return val; },
        Op#Add { a, b } => { return a + b; },
        Op#Mul { a, b } => { return a * b; },
        Op#Neg { val } => { return 0 - val; },
        Op#Sub { a, b } => { return a - b; }
    }
}

// --- Stack machine ---

pub enum Copy StackCmd {
    Push { val: i32 },
    DupTop {},
    AddTop {},
    MulTop {},
    NegTop {},
    SwapTop {},
}

pub struct Copy Stack {
    s0: i32,
    s1: i32,
    s2: i32,
    s3: i32,
    depth: i32,
}

fn stack_new() -> Stack {
    return Stack { s0: 0, s1: 0, s2: 0, s3: 0, depth: 0 };
}

fn stack_push(st: &Stack, val: i32) -> Stack {
    return Stack {
        s0: val,
        s1: st.s0,
        s2: st.s1,
        s3: st.s2,
        depth: st.depth + 1,
    };
}

fn stack_top(st: &Stack) -> i32 {
    return st.s0;
}

fn stack_pop(st: &Stack) -> Stack {
    return Stack {
        s0: st.s1,
        s1: st.s2,
        s2: st.s3,
        s3: 0,
        depth: st.depth - 1,
    };
}

fn execute_cmd(st: &Stack, cmd: &StackCmd) -> Stack {
    match *cmd {
        StackCmd#Push { val } => {
            return stack_push(st, val);
        },
        StackCmd#DupTop {} => {
            let top: i32 = stack_top(st);
            return stack_push(st, top);
        },
        StackCmd#AddTop {} => {
            let a: i32 = st.s0;
            let b: i32 = st.s1;
            let popped: Stack = stack_pop(st);
            let popped2: Stack = stack_pop(&popped);
            return stack_push(&popped2, a + b);
        },
        StackCmd#MulTop {} => {
            let a: i32 = st.s0;
            let b: i32 = st.s1;
            let popped: Stack = stack_pop(st);
            let popped2: Stack = stack_pop(&popped);
            return stack_push(&popped2, a * b);
        },
        StackCmd#NegTop {} => {
            let top: i32 = st.s0;
            let popped: Stack = stack_pop(st);
            return stack_push(&popped, 0 - top);
        },
        StackCmd#SwapTop {} => {
            return Stack {
                s0: st.s1,
                s1: st.s0,
                s2: st.s2,
                s3: st.s3,
                depth: st.depth,
            };
        }
    }
}

// --- Expression tree evaluator (flattened) ---
// Evaluate: ((3 + 4) * (2 + 1)) - (5 - 2) = 7 * 3 - 3 = 21 - 3 = 18

fn eval_tree() -> i32 {
    let add1: Op = Op#Add { a: 3, b: 4 };
    let add2: Op = Op#Add { a: 2, b: 1 };
    let v1: i32 = eval_op(&add1);
    let v2: i32 = eval_op(&add2);

    let mul: Op = Op#Mul { a: v1, b: v2 };
    let v3: i32 = eval_op(&mul);

    let sub: Op = Op#Sub { a: 5, b: 2 };
    let v4: i32 = eval_op(&sub);

    let final_sub: Op = Op#Sub { a: v3, b: v4 };
    return eval_op(&final_sub);
}

// --- Stack machine computation ---
// Compute: push 4, push 6, add (=10), push 2, mul (=20), push 4, add (=24)

fn compute_stack() -> i32 {
    let c0: StackCmd = StackCmd#Push { val: 4 };
    let c1: StackCmd = StackCmd#Push { val: 6 };
    let c2: StackCmd = StackCmd#AddTop {};
    let c3: StackCmd = StackCmd#Push { val: 2 };
    let c4: StackCmd = StackCmd#MulTop {};
    let c5: StackCmd = StackCmd#Push { val: 4 };
    let c6: StackCmd = StackCmd#AddTop {};

    let s0: Stack = stack_new();
    let s1: Stack = execute_cmd(&s0, &c0);
    let s2: Stack = execute_cmd(&s1, &c1);
    let s3: Stack = execute_cmd(&s2, &c2);
    let s4: Stack = execute_cmd(&s3, &c3);
    let s5: Stack = execute_cmd(&s4, &c4);
    let s6: Stack = execute_cmd(&s5, &c5);
    let s7: Stack = execute_cmd(&s6, &c6);

    return stack_top(&s7);
}

fn main() -> Int {
    let tree_result: i32 = eval_tree();       // 18
    let stack_result: i32 = compute_stack();  // 24

    // 18 + 24 = 42
    let result: i32 = tree_result + stack_result;
    return result as Int;
}
