// Bug 018 repro: borrowing a stack array as a mutable pointer can write into
// a copy instead of the original stack storage. This file is a dedicated repro
// artifact for the bug ledger and should become a passing regression once the
// underlying borrow/materialization bug is fixed.

trusted extern fn memset(ptr: *mut u8, value: i32, n: u64) -> *mut u8;

fn main() with(Unsafe) -> Int {
    let buf: [u8; 4] = [0; 4];
    memset(&buf as *mut u8, 65, 4);

    let v0: u8 = buf[0];
    let v1: u8 = buf[1];
    let v2: u8 = buf[2];
    let v3: u8 = buf[3];

    if v0 == 65 && v1 == 65 && v2 == 65 && v3 == 65 {
        return 42;
    }
    return 1;
}
