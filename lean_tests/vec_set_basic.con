// Test: exercise vec_set — set element at index and retrieve it
fn main() with(Alloc) -> Int {
    let mut v: Vec<Int> = vec_new::<Int>();
    vec_push(&mut v, 10);
    vec_push(&mut v, 20);
    vec_push(&mut v, 30);
    vec_set(&mut v, 1, 99);
    let val: Int = vec_get(&v, 1);
    vec_free(v);
    return val;
}
