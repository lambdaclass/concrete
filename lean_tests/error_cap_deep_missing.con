// Error: missing capability in deep call chain
trusted extern fn putchar(c: i32) -> i32;

trusted fn print_int(x: i64) with(Console) {
    let s: String = int_to_string(x);
    let len: Int = string_length(&s);
    let mut i: Int = 0;
    while i < len {
        let ch: Int = string_char_at(&s, i);
        putchar(ch as i32);
        i = i + 1;
    }
    putchar(10);
    drop_string(s);
}

fn inner() with(Console) -> Int {
    print_int(1);
    return 1;
}

fn outer() -> Int {
    return inner();
}

fn main() -> Int {
    return outer();
}
