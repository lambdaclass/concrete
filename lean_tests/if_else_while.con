// Test: while loop in both branches of if/else (SSA domination)
fn count_up(n: Int) -> Int {
    let mut total: Int = 0;
    if n > 0 {
        let mut i: Int = 0;
        while i < n {
            total = total + 1;
            i = i + 1;
        }
    } else {
        let mut i: Int = 0;
        while i < 5 {
            total = total + 2;
            i = i + 1;
        }
    }
    return total;
}

fn main() -> Int {
    return count_up(3);
}
