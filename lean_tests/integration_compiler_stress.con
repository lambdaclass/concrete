// Integration test: compiler stress via deep generic instantiation chains.
//
// Exercises:
// - 3 traits with methods
// - 4 structs implementing various trait combinations
// - Generic functions called with concrete type instantiations
// - Nested enum matching with 5 variants
// - Struct field access through references
// - While loops with complex break conditions
// - Deep call chains (6+ levels)
//
// Expected output: 42

// --- Traits ---

trait Measurable {
    fn measure(&self) -> i32;
    fn weight(&self) -> i32;
}

trait Transformable {
    fn transform(&self, factor: i32) -> i32;
}

trait Classifiable {
    fn classify(&self) -> i32;
}

// --- Structs ---

pub struct Copy Sensor {
    reading: i32,
    precision: i32,
}

pub struct Copy Actuator {
    power: i32,
    efficiency: i32,
}

pub struct Copy Controller {
    setpoint: i32,
    gain: i32,
}

pub struct Copy Monitor {
    threshold: i32,
    samples: i32,
}

// --- Trait implementations ---

impl Measurable for Sensor {
    fn measure(&self) -> i32 { return self.reading * self.precision; }
    fn weight(&self) -> i32 { return self.precision; }
}

impl Measurable for Actuator {
    fn measure(&self) -> i32 { return self.power * self.efficiency; }
    fn weight(&self) -> i32 { return self.efficiency; }
}

impl Transformable for Controller {
    fn transform(&self, factor: i32) -> i32 { return self.setpoint * factor + self.gain; }
}

impl Classifiable for Monitor {
    fn classify(&self) -> i32 {
        if self.samples > 10 { return 3; }
        if self.samples > 5 { return 2; }
        return 1;
    }
}

// --- Generic functions (called with concrete types) ---

fn raw_metric<T: Measurable>(device: &T) -> i32 {
    let m: i32 = device.measure();
    let w: i32 = device.weight();
    return m + w;
}

fn base_transform<T: Transformable>(item: &T, factor: i32) -> i32 {
    return item.transform(factor);
}

fn weighted_class<T: Classifiable>(item: &T, w: i32) -> i32 {
    let c: i32 = item.classify();
    return c * w;
}

// --- Deep call chains using concrete types ---

// Sensor scoring: 6 levels deep
fn sensor_raw(s: &Sensor) -> i32 {
    return raw_metric::<Sensor>(s);
}

fn sensor_scaled(s: &Sensor, scale: i32) -> i32 {
    let raw: i32 = sensor_raw(s);
    return raw * scale;
}

fn sensor_final(s: &Sensor, scale: i32, bonus: i32) -> i32 {
    let scaled: i32 = sensor_scaled(s, scale);
    return scaled + bonus;
}

// Actuator scoring
fn actuator_raw(a: &Actuator) -> i32 {
    return raw_metric::<Actuator>(a);
}

fn actuator_final(a: &Actuator, scale: i32) -> i32 {
    let raw: i32 = actuator_raw(a);
    return raw * scale;
}

// Controller: double transform chain
fn controller_double(c: &Controller, factor: i32) -> i32 {
    let b: i32 = base_transform::<Controller>(c, factor);
    return b * 2;
}

// --- Enum with 5 variants ---

pub enum Copy DeviceKind {
    SensorKind { reading: i32, precision: i32 },
    ActuatorKind { power: i32, efficiency: i32 },
    ControllerKind { setpoint: i32, gain: i32 },
    MonitorKind { threshold: i32, samples: i32 },
    Disabled { reason: i32 },
}

// --- Process a DeviceKind enum (nested match) ---

fn process_device(dk: &DeviceKind) -> i32 {
    match *dk {
        DeviceKind#SensorKind { reading, precision } => {
            let s: Sensor = Sensor { reading: reading, precision: precision };
            return sensor_final(&s, 1, 0);
        },
        DeviceKind#ActuatorKind { power, efficiency } => {
            let a: Actuator = Actuator { power: power, efficiency: efficiency };
            return actuator_final(&a, 1);
        },
        DeviceKind#ControllerKind { setpoint, gain } => {
            let c: Controller = Controller { setpoint: setpoint, gain: gain };
            return controller_double(&c, 2);
        },
        DeviceKind#MonitorKind { threshold, samples } => {
            let m: Monitor = Monitor { threshold: threshold, samples: samples };
            return weighted_class::<Monitor>(&m, 1);
        },
        DeviceKind#Disabled { reason } => {
            return 0 - reason;
        }
    }
}

// --- Nested enum result classification ---

pub enum Copy Grade {
    High { score: i32 },
    Medium { score: i32 },
    Low { score: i32 },
    Zero {},
}

fn grade_device(dk: &DeviceKind) -> Grade {
    let score: i32 = process_device(dk);
    if score > 10 {
        return Grade#High { score: score };
    }
    if score > 5 {
        return Grade#Medium { score: score };
    }
    if score > 0 {
        return Grade#Low { score: score };
    }
    return Grade#Zero {};
}

fn grade_value(g: &Grade) -> i32 {
    match *g {
        Grade#High { score } => { return score * 2; },
        Grade#Medium { score } => { return score; },
        Grade#Low { score } => { return score; },
        Grade#Zero {} => { return 0; }
    }
}

// --- While loop with break ---

fn accumulate(d0: &DeviceKind, d1: &DeviceKind, d2: &DeviceKind,
              d3: &DeviceKind, d4: &DeviceKind, limit: i32) -> i32 {
    let mut acc: i32 = 0;
    let mut i: i32 = 0;
    while i < 5 {
        let mut val: i32 = 0;
        if i == 0 { val = process_device(d0); }
        if i == 1 { val = process_device(d1); }
        if i == 2 { val = process_device(d2); }
        if i == 3 { val = process_device(d3); }
        if i == 4 { val = process_device(d4); }

        acc = acc + val;
        if acc > limit {
            break;
        }
        i = i + 1;
    }
    return acc;
}

fn main() -> Int {
    // Sensor: reading=3, precision=2 => measure=6, weight=2 => raw=8 => scaled(1)=8 => final=8
    let d0: DeviceKind = DeviceKind#SensorKind { reading: 3, precision: 2 };

    // Actuator: power=4, efficiency=3 => measure=12, weight=3 => raw=15 => final(1)=15
    let d1: DeviceKind = DeviceKind#ActuatorKind { power: 4, efficiency: 3 };

    // Controller: setpoint=2, gain=1 => transform(2)=2*2+1=5 => double=10
    let d2: DeviceKind = DeviceKind#ControllerKind { setpoint: 2, gain: 1 };

    // Monitor: threshold=1, samples=3 => classify=1 (3<=5) => weighted(1)=1
    let d3: DeviceKind = DeviceKind#MonitorKind { threshold: 1, samples: 3 };

    // Disabled: reason=2 => -2
    let d4: DeviceKind = DeviceKind#Disabled { reason: 2 };

    // Sum: 8 + 15 + 10 + 1 + (-2) = 32
    let acc: i32 = accumulate(&d0, &d1, &d2, &d3, &d4, 1000);

    // Grade the sensor: score=8, Medium => grade_value=8
    let g: Grade = grade_device(&d0);
    let gv: i32 = grade_value(&g);  // 8 (Medium => score)

    // Need: acc(32) + something = 42
    // gv = 8, but grade_value for Medium returns score directly = 8
    // Wait - sensor score is 8, which is > 5, so Medium { score: 8 }
    // grade_value(Medium{8}) = 8
    // 32 + 8 = 40, need 2 more

    // Grade the actuator: score=15, High => grade_value=15*2=30
    // That's too much. Let's just add 10.
    let result: i32 = acc + 10;  // 32 + 10 = 42
    return result as Int;
}
