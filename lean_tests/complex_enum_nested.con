// Enum containing struct payloads: tests nested type construction and matching
struct Copy Point { x: Int, y: Int }

enum Shape {
    Circle { center: Point, radius: Int },
    Rect { origin: Point, w: Int, h: Int },
}

fn area(s: Shape) -> Int {
    match s {
        Shape#Circle { center, radius } => {
            // approximate: radius * radius * 3
            return radius * radius * 3;
        },
        Shape#Rect { origin, w, h } => {
            return w * h;
        },
    }
}

fn main() -> Int {
    let c: Shape = Shape#Circle { center: Point { x: 0, y: 0 }, radius: 5 };
    let r: Shape = Shape#Rect { origin: Point { x: 1, y: 2 }, w: 3, h: 4 };
    return area(c) + area(r);
}
