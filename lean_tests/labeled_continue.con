fn main() -> Int {
    let mut sum: Int = 0;
    let mut i: Int = 0;
    'outer: while i < 5 {
        i = i + 1;
        let mut j: Int = 0;
        while j < 5 {
            j = j + 1;
            if j == 3 {
                continue 'outer;
            }
        }
        sum = sum + 10;
    }
    return sum;
}
