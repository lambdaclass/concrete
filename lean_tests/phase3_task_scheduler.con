// Phase 3 mixed-feature test: task scheduler
//
// Combines: enums (task state with 4 variants, priority with 3 variants),
//   structs (Task encoded in Vec), Vec operations, while loops, match,
//   capabilities (Alloc via Std), defer (cleanup of Vecs), modules,
//   function pointers (task execution functions).
//
// A task scheduler manages a flat Vec of tasks. Each task has:
//   [id, state_tag, priority, result]
// States: 0=Pending, 1=Running, 2=Done, 3=Failed
// Priority: 0=Low, 1=Normal, 2=High
//
// Scheduler picks highest-priority pending task, "runs" it via a function pointer,
// transitions state based on result. Repeats until no pending tasks remain.
//
// Expected output: 42

mod TaskDefs {
    pub enum Copy TaskState {
        Pending {},
        Running {},
        Done { result: i32 },
        Failed { error_code: i32 },
    }

    pub enum Copy Priority {
        Low {},
        Normal {},
        High {},
    }

    pub fn state_to_tag(s: &TaskState) -> i32 {
        match *s {
            TaskState#Pending {} => { return 0; },
            TaskState#Running {} => { return 1; },
            TaskState#Done { result } => { return 2; },
            TaskState#Failed { error_code } => { return 3; }
        }
    }

    pub fn tag_to_state(tag: i32, result_val: i32) -> TaskState {
        if tag == 0 { return TaskState#Pending {}; }
        if tag == 1 { return TaskState#Running {}; }
        if tag == 2 { return TaskState#Done { result: result_val }; }
        return TaskState#Failed { error_code: result_val };
    }

    pub fn priority_to_tag(p: &Priority) -> i32 {
        match *p {
            Priority#Low {} => { return 0; },
            Priority#Normal {} => { return 1; },
            Priority#High {} => { return 2; }
        }
    }

    pub fn priority_value(tag: i32) -> i32 {
        // Higher tag = higher priority
        return tag;
    }
}

mod Scheduler {
    import TaskDefs.{ TaskState, Priority, state_to_tag, tag_to_state, priority_value };

    // Task storage: 4 i32s per task [id, state_tag, priority_tag, result_value]
    pub fn add_task(tasks: &mut Vec<i32>, id: i32, priority_tag: i32) with(Alloc) {
        vec_push::<i32>(tasks, id);
        vec_push::<i32>(tasks, 0);  // Pending
        vec_push::<i32>(tasks, priority_tag);
        vec_push::<i32>(tasks, 0);  // no result yet
    }

    pub fn task_count(tasks: &mut Vec<i32>) -> i32 {
        return vec_len::<i32>(tasks) as i32 / 4;
    }

    fn get_state_tag(tasks: &mut Vec<i32>, task_idx: i32) -> i32 {
        let base: Int = (task_idx * 4) as Int;
        return vec_get::<i32>(tasks, base + 1);
    }

    fn get_priority_tag(tasks: &mut Vec<i32>, task_idx: i32) -> i32 {
        let base: Int = (task_idx * 4) as Int;
        return vec_get::<i32>(tasks, base + 2);
    }

    fn get_task_id(tasks: &mut Vec<i32>, task_idx: i32) -> i32 {
        let base: Int = (task_idx * 4) as Int;
        return vec_get::<i32>(tasks, base);
    }

    fn get_result(tasks: &mut Vec<i32>, task_idx: i32) -> i32 {
        let base: Int = (task_idx * 4) as Int;
        return vec_get::<i32>(tasks, base + 3);
    }

    fn set_state(tasks: &mut Vec<i32>, task_idx: i32, state_tag: i32, result_val: i32) {
        let base: Int = (task_idx * 4) as Int;
        vec_set::<i32>(tasks, base + 1, state_tag);
        vec_set::<i32>(tasks, base + 3, result_val);
    }

    // Find the highest-priority pending task. Returns -1 if none.
    pub fn find_next(tasks: &mut Vec<i32>) -> i32 {
        let count: i32 = task_count(tasks);
        let mut best_idx: i32 = 0 - 1;
        let mut best_pri: i32 = 0 - 1;
        let mut i: i32 = 0;
        while i < count {
            let st: i32 = get_state_tag(tasks, i);
            if st == 0 {
                let pri: i32 = get_priority_tag(tasks, i);
                if pri > best_pri {
                    best_pri = pri;
                    best_idx = i;
                }
            }
            i = i + 1;
        }
        return best_idx;
    }

    // Execute a task using a function pointer that takes task_id and returns a result.
    // Positive result => Done, negative => Failed.
    pub fn execute_task(tasks: &mut Vec<i32>, task_idx: i32,
                        exec_fn: fn(i32) -> i32) {
        let tid: i32 = get_task_id(tasks, task_idx);
        // Mark as running
        set_state(tasks, task_idx, 1, 0);
        // Execute
        let result: i32 = exec_fn(tid);
        // Transition based on result
        if result >= 0 {
            set_state(tasks, task_idx, 2, result);
        } else {
            set_state(tasks, task_idx, 3, result);
        }
    }

    // Run the scheduler to completion
    pub fn run_all(tasks: &mut Vec<i32>, exec_fn: fn(i32) -> i32) {
        let mut iterations: i32 = 0;
        let max_iter: i32 = 100;  // safety bound
        while iterations < max_iter {
            let next: i32 = find_next(tasks);
            if next < 0 { return; }
            execute_task(tasks, next, exec_fn);
            iterations = iterations + 1;
        }
    }

    // Count tasks in a given state
    pub fn count_in_state(tasks: &mut Vec<i32>, target_state: i32) -> i32 {
        let count: i32 = task_count(tasks);
        let mut result: i32 = 0;
        let mut i: i32 = 0;
        while i < count {
            if get_state_tag(tasks, i) == target_state {
                result = result + 1;
            }
            i = i + 1;
        }
        return result;
    }

    // Sum results of all Done tasks
    pub fn sum_done_results(tasks: &mut Vec<i32>) -> i32 {
        let count: i32 = task_count(tasks);
        let mut sum: i32 = 0;
        let mut i: i32 = 0;
        while i < count {
            if get_state_tag(tasks, i) == 2 {
                sum = sum + get_result(tasks, i);
            }
            i = i + 1;
        }
        return sum;
    }

    // Sum results of all Failed tasks (negative values)
    pub fn sum_failed_results(tasks: &mut Vec<i32>) -> i32 {
        let count: i32 = task_count(tasks);
        let mut sum: i32 = 0;
        let mut i: i32 = 0;
        while i < count {
            if get_state_tag(tasks, i) == 3 {
                sum = sum + get_result(tasks, i);
            }
            i = i + 1;
        }
        return sum;
    }
}

mod Main {
    import TaskDefs.{ TaskState, tag_to_state, state_to_tag };
    import Scheduler.{ add_task, task_count, find_next, run_all, count_in_state, sum_done_results, sum_failed_results };

    // Task execution function: tasks 1-5 succeed with result = id*3,
    // task 6 fails with result = -1, task 7 succeeds with result = id*2
    fn execute(task_id: i32) -> i32 {
        if task_id == 6 { return 0 - 1; }
        if task_id == 7 { return task_id * 2; }
        return task_id * 3;
    }

    fn main() with(Std) -> Int {
        let mut tasks: Vec<i32> = vec_new::<i32>();

        // Add 7 tasks with varying priorities
        add_task(&mut tasks, 1, 0);   // Low
        add_task(&mut tasks, 2, 1);   // Normal
        add_task(&mut tasks, 3, 2);   // High
        add_task(&mut tasks, 4, 1);   // Normal
        add_task(&mut tasks, 5, 0);   // Low
        add_task(&mut tasks, 6, 2);   // High (will fail)
        add_task(&mut tasks, 7, 1);   // Normal

        if task_count(&mut tasks) != 7 { vec_free::<i32>(tasks); return 1; }

        // All should be Pending initially
        if count_in_state(&mut tasks, 0) != 7 { vec_free::<i32>(tasks); return 2; }

        // First scheduled should be a High-priority task (idx 2 or 5, both pri=2)
        let first: i32 = find_next(&mut tasks);
        if first != 2 { if first != 5 { vec_free::<i32>(tasks); return 3; } }

        // Test enum round-trip
        let ts: TaskState = tag_to_state(2, 99);
        let tag: i32 = state_to_tag(&ts);
        if tag != 2 { vec_free::<i32>(tasks); return 4; }

        // Run all tasks
        run_all(&mut tasks, execute);

        // Check final states
        let pending_count: i32 = count_in_state(&mut tasks, 0);   // 0
        let running_count: i32 = count_in_state(&mut tasks, 1);   // 0
        let done_count: i32 = count_in_state(&mut tasks, 2);      // 6
        let failed_count: i32 = count_in_state(&mut tasks, 3);    // 1

        if pending_count != 0 { vec_free::<i32>(tasks); return 5; }
        if running_count != 0 { vec_free::<i32>(tasks); return 6; }
        if done_count != 6 { vec_free::<i32>(tasks); return 7; }
        if failed_count != 1 { vec_free::<i32>(tasks); return 8; }

        // Sum of done results: 1*3 + 2*3 + 3*3 + 4*3 + 5*3 + 7*2 = 3+6+9+12+15+14 = 59
        let done_sum: i32 = sum_done_results(&mut tasks);
        if done_sum != 59 { vec_free::<i32>(tasks); return 9; }

        // Sum of failed results: -1
        let fail_sum: i32 = sum_failed_results(&mut tasks);
        if fail_sum != 0 - 1 { vec_free::<i32>(tasks); return 10; }

        // Final checksum: done_sum(59) + fail_sum(-1) - done_count(6) * 2 - failed_count(1) * 4
        // = 59 - 1 - 12 - 4 = 42
        let checksum: i32 = done_sum + fail_sum - done_count * 2 - failed_count * 4;
        if checksum != 42 { vec_free::<i32>(tasks); return 11; }

        vec_free::<i32>(tasks);
        return checksum as Int;
    }
}
