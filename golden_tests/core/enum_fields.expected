// module main
enum Option<T> {
  Some { value: T },
  None,
}

enum Result<T, E> {
  Ok { value: T },
  Err { value: E },
}

enum Shape {
  Circle { radius: Int },
  Rect { w: Int, h: Int },
}

fn area(s: Shape) -> Int {
  match s {
  Shape::Circle { radius: Int } -> {
      return (radius * radius);
  }
  Shape::Rect { w: Int, h: Int } -> {
      return (w * h);
  }
};
}

fn main() -> Int {
  let s: Shape = Shape::Rect { w: 3, h: 4 };
  return area(s);
}
