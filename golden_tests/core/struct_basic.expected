// module main
struct Point {
  x: Int,
  y: Int,
}

enum Option<T> {
  Some { value: T },
  None,
}

enum Result<T, E> {
  Ok { value: T },
  Err { value: E },
}

fn sum_point(p: Point) -> Int {
  return (p.x + p.y);
}

fn main() -> Int {
  let p: Point = Point { x: 3, y: 4 };
  return sum_point(p);
}
