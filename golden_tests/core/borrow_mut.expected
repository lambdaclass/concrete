// module main
struct Box {
  value: Int,
}

enum Option<T> {
  Some { value: T },
  None,
}

enum Result<T, E> {
  Ok { value: T },
  Err { value: E },
}

fn set_value(b: &mut Box, v: Int) -> () {
  b.value = v;
}

fn consume(b: Box) -> Int {
  return b.value;
}

fn main() -> Int {
  let mut b: Box = Box { value: 0 };
  set_value(&mut b, 99);
  return consume(b);
}
