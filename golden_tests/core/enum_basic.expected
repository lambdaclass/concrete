// module main
enum Option<T> {
  Some { value: T },
  None,
}

enum Result<T, E> {
  Ok { value: T },
  Err { value: E },
}

enum Color {
  Red,
  Green,
  Blue,
}

fn pick(c: Color) -> Int {
  match c {
  Color::Red -> {
      return 1;
  }
  Color::Green -> {
      return 2;
  }
  Color::Blue -> {
      return 3;
  }
};
}

fn main() -> Int {
  let c: Color = Color::Green;
  return pick(c);
}
