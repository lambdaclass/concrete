; module main
define i64 @pick(%Color %c) {
entry:
  %t1 = load i32, %c
  %t2 = cast i32 %t1 to i64
  %t3 = eq i1 %t2, 0
  br i1 %t3, label %arm01, label %check12
arm01:

  ret i64 1
check12:
  %t5 = eq i1 %t2, 1
  br i1 %t5, label %arm13, label %check24
arm13:

  ret i64 2
check24:
  %t7 = eq i1 %t2, 2
  br i1 %t7, label %arm25, label %check36
arm25:

  ret i64 3
check36:

  unreachable
}

define i64 @main() {
entry:
  %t0 = alloca %Color
  store i32 1, %t0
  %t2 = load %Color, %t0
  %t3 = call i64 @pick(%Color %t2)
  ret i64 %t3
}
