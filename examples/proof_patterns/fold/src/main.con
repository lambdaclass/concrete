// proof_patterns: fold / reduction proof.
// Sums a fixed [i32; 4] with a counted loop (bounds fed by the invariant); the
// proof shows the fold computes the correct total on a concrete input.
mod fold {
    #[spec(Examples.ProofPatterns.Proofs.sum4Expr)]
    #[proof_by(Examples.ProofPatterns.Proofs.sum4_totals_concrete)]
    #[proof_coverage(point)]
    #[proof_fingerprint("408e0bd28773a5aedb749482c4934b18")]
    fn sum4(a: [i32; 4]) -> i32 {
        let mut acc: i32 = 0;
        #[invariant(0 <= i && i <= 4)]
        #[variant(4 - i)]
        for (let mut i: i32 = 0; i < 4; i = i + 1) {
            acc = acc + a[i];
        }
        return acc;
    }
}
