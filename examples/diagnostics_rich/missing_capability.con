// Phase 4 #4 fixture — capability family: a function uses Alloc (Vec) without
// declaring the capability. Human and JSON renderings must agree (one record).
fn sneaky_alloc() -> Int {
    let mut v: Vec<Int> = vec_new::<Int>();
    vec_push(&mut v, 42);
    let val: Int = vec_get(&v, 0);
    vec_free(v);
    return val;
}

fn main() with(Std) -> Int {
    return sneaky_alloc();
}
