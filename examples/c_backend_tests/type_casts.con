mod TypeCasts {
    fn main() -> i32 {
        let a: i8 = 10;
        let b: i16 = a as i16;
        let c: i32 = b as i32;
        let d: i64 = c as i64;

        let e: u8 = 200;
        let f: u32 = e as u32;

        let g: f32 = 3.14f32;
        let h: i32 = g as i32;

        return c + (f as i32) + h;  // 10 + 200 + 3 = 213
    }
}
