mod Math {
    pub fn square(x: i32) -> i32 {
        return x * x;
    }

    pub fn double(x: i32) -> i32 {
        return x * 2;
    }
}

mod Main {
    import Math.{square, double};

    fn main() -> i32 {
        let a: i32 = square(3);    // 9
        let b: i32 = double(5);    // 10
        return a + b;              // 19
    }
}
