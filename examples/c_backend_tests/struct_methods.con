mod StructMethods {
    struct Counter {
        value: i32,
    }

    impl Counter {
        pub fn new(initial: i32) -> Counter {
            return Counter { value: initial };
        }

        pub fn get(&self) -> i32 {
            return self.value;
        }

        pub fn increment(&mut self) {
            self.value = self.value + 1;
        }

        pub fn add(&mut self, amount: i32) {
            self.value = self.value + amount;
        }
    }

    fn main() -> i32 {
        let mut counter: Counter = Counter::new(10);
        counter.increment();
        counter.add(5);
        return counter.get();  // 10 + 1 + 5 = 16
    }
}
