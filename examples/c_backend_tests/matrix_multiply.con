mod MatrixMultiply {
    fn main() -> i32 {
        let a: [[i32; 2]; 2] = [
            [1, 2],
            [3, 4]
        ];

        let b: [[i32; 2]; 2] = [
            [5, 6],
            [7, 8]
        ];

        let mut result: [[i32; 2]; 2] = [
            [0, 0],
            [0, 0]
        ];

        // Matrix multiplication
        let mut i: i64 = 0;
        while i < 2 {
            let mut j: i64 = 0;
            while j < 2 {
                let mut k: i64 = 0;
                while k < 2 {
                    result[i][j] = result[i][j] + a[i][k] * b[k][j];
                    k = k + 1;
                }
                j = j + 1;
            }
            i = i + 1;
        }

        // result = [[19, 22], [43, 50]]
        // Sum all elements = 19 + 22 + 43 + 50 = 134
        return result[0][0] + result[0][1] + result[1][0] + result[1][1];
    }
}
