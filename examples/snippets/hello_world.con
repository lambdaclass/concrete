mod hello {
    extern fn malloc(size: u64) -> *mut u8;
    extern fn puts(ptr: *mut u8) -> i32;

    #[langitem = "String"]
    struct String {
        ptr: *mut u8,
        len: u64,
        cap: u64,
    }

    extern fn free(ptr: *mut u8);

    fn main() with(Unsafe) -> u64 {
        let x: String = "hello \nworld!";
        puts(x.ptr);
        let String { ptr, len, cap } = x;
        free(ptr);
        return 0;
    }
}
